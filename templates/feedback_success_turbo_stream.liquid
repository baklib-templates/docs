{% layout none %}

{% assign toast_message = success | presence %}
{% unless toast_message %}
  {% assign toast_message = 'templates.feedback.success_message' | t: '感谢您的反馈，我们会持续优化内容体验。' %}
{% endunless %}

<turbo-stream action="remove" target="js--feedback-modal"></turbo-stream>

<turbo-stream action="replace" target="js--feedback-{{ page.id }}">
  <template>
    {% render 'index/page_feedback', page: page %}
  </template>
</turbo-stream>

{% if page.full_slug == '/' %}
  <turbo-stream action="replace" target="js--home-feedback-{{ page.id }}">
    <template>
      {% render 'index/home_feedback_form', page: page %}
    </template>
  </turbo-stream>

  <turbo-stream action="append" target="js--body">
    <template>
      <script>
        document.getElementById('home-feedback-modal')?.close();
      </script>
    </template>
  </turbo-stream>
{% endif %}

<turbo-stream action="remove" target="js--feedback-toast"></turbo-stream>
<turbo-stream action="remove" target="js--feedback-error"></turbo-stream>

<turbo-stream action="append" target="js--body">
  <template>
    {% render 'feedback_toast', variant: 'success', message: toast_message %}
  </template>
</turbo-stream>
