{% assign index_page = site.pages['/'] %}

{% if index_page.template_style == 'mint' %}
	{% render 'index/mint/container', page: page %}
{% elsif index_page.template_style == 'maple' %}
	{% render 'index/maple/container', page: page %}
{% elsif index_page.template_style == 'palm' %}
	{% render 'index/palm/container', page: page %}
{% elsif index_page.template_style == 'willow' %}
	{% render 'index/willow/container', page: page %}
{% elsif index_page.template_style == 'linden' %}
	{% render 'index/linden/container', page: page %}
{% elsif index_page.template_style == 'almond' %}
	{% render 'index/almond/container', page: page %}
{% endif %}

{% schema %}
{
	"name": "page",
	"description": "t:schema.templates.page.description",
	"thumb_url": "images/schema/page.png",
	"sub_page_templates": ["page"],
	"force_sub_page_template": true,
	"settings": [
		{
			"id": "show_list",
			"type": "checkbox",
			"default": false,
			"label": "t:schema.templates.page.settings.show_list.label",
			"info": "t:schema.templates.page.settings.show_list.info"
		},
		{
			"id": "show_on_home_guide",
			"type": "checkbox",
			"default": false,
			"label": "t:schema.templates.page.settings.show_on_home_guide.label",
			"info": "t:schema.templates.page.settings.show_on_home_guide.info",
			"queryable": true
		},
		{
			"id": "icon",
			"type": "image_picker",
			"ratio": "1:1",
			"width": 100,
			"label": "t:schema.templates.page.settings.icon.label",
			"info": "t:schema.templates.page.settings.icon.info"
		},
		{
			"id": "title",
			"type": "text",
			"readonly": true,
			"label": "t:schema.templates.page.settings.title.label",
			"info": "t:schema.templates.page.settings.title.info",
			"to_markdown": true
		},
		{
			"id": "description",
			"type": "textarea",
			"label": "t:schema.templates.page.settings.description.label",
			"to_markdown": true
		},
		{
			"id": "tags",
			"type": "tag_picker",
			"multiple": true,
			"label": "t:schema.templates.page.settings.tags.label",
			"queryable": true,
			"to_markdown": true
		},
		{
			"id": "content",
			"type": "richtext",
			"label": "t:schema.templates.page.settings.content.label",
			"readonly": true,
			"info": "t:schema.templates.page.settings.content.info",
			"to_markdown": true
		}
	]
}
{% endschema %}