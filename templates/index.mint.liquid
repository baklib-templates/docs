{% render 'index/mint/container', page: page %}

{% schema %}
  {
    "name": "t:schema.templates.index.mint.name",
    "description": "t:schema.templates.index.mint.description",
    "thumb_url": "images/schema/index-mint.png",
    "preview_image_urls": [
      "images/schema/index-mint.png"
    ],
    "sub_page_templates": ["page"],
    "force_sub_page_template": true,
    "settings": [
      { "type": "header", "content": "t:schema.templates.index.shared.groups.home_config" },
      { "type": "paragraph", "content": "t:schema.templates.index.shared.groups.home_config_info_mint" },
      {
        "id": "home_page_path",
        "type": "text",
        "label": "t:schema.templates.index.shared.settings.home_page_path.label",
        "info": "t:schema.templates.index.shared.settings.home_page_path.info",
        "placeholder": "/docs/getting-started"
      },
      {
        "id": "home_hero_title",
        "type": "text",
        "label": "t:schema.templates.index.mint.settings.home_hero_title.label",
        "default": "t:schema.templates.index.mint.settings.home_hero_title.default"
      },
      {
        "id": "home_hero_description",
        "type": "textarea",
        "label": "t:schema.templates.index.mint.settings.home_hero_description.label",
        "default": "t:schema.templates.index.mint.settings.home_hero_description.default",
        "rows": 3
      },
      {
        "id": "search_hot_keywords",
        "type": "textarea",
        "label": "t:schema.templates.index.shared.settings.search_hot_keywords.label",
        "info": "t:schema.templates.index.shared.settings.search_hot_keywords.info",
        "default": "t:schema.templates.index.mint.settings.search_hot_keywords.default",
        "rows": 4
      },
      {
        "id": "home_guide_section_title",
        "type": "text",
        "label": "t:schema.templates.index.mint.settings.home_guide_section_title.label",
        "default": "t:schema.templates.index.mint.settings.home_guide_section_title.default"
      },
      {
        "id": "home_show_guide_section",
        "type": "checkbox",
        "label": "t:schema.templates.index.mint.settings.home_show_guide_section.label",
        "default": true
      },
      {
        "id": "home_recommended_title",
        "type": "text",
        "label": "t:schema.templates.index.mint.settings.home_recommended_title.label",
        "default": "t:schema.templates.index.mint.settings.home_recommended_title.default"
      },
      {
        "id": "home_show_recommended",
        "type": "checkbox",
        "label": "t:schema.templates.index.mint.settings.home_show_recommended.label",
        "default": true
      },
      {
        "id": "home_help_title",
        "type": "text",
        "label": "t:schema.templates.index.mint.settings.home_help_title.label",
        "default": "t:schema.templates.index.mint.settings.home_help_title.default"
      },
      {
        "id": "home_help_description",
        "type": "textarea",
        "label": "t:schema.templates.index.mint.settings.home_help_description.label",
        "default": "t:schema.templates.index.mint.settings.home_help_description.default",
        "rows": 3
      },

      { "type": "header", "content": "t:schema.templates.index.shared.groups.chrome" },
      {
        "id": "screen_width",
        "type": "radio",
        "label": "t:schema.generic.settings.screen_width.label",
        "choices": [
          { "label": "t:schema.generic.settings.screen_width.choices.narrow", "value": "1024px" },
          { "label": "t:schema.generic.settings.screen_width.choices.medium", "value": "1280px" },
          { "label": "t:schema.generic.settings.screen_width.choices.wide", "value": "1536px" },
          { "label": "t:schema.generic.settings.screen_width.choices.full", "value": "100%" }
        ],
        "default": "1280px"
      },
      {
        "id": "left_sidebar_width",
        "type": "range",
        "label": "t:schema.generic.settings.left_sidebar_width.label",
        "min": 200,
        "max": 600,
        "step": 1,
        "default": 240,
        "info": "t:schema.templates.index.mint.settings.left_sidebar_width.info"
      },
      {
        "id": "right_sidebar_width",
        "type": "range",
        "label": "t:schema.generic.settings.right_sidebar_width.label",
        "min": 200,
        "max": 1200,
        "step": 1,
        "default": 240,
        "info": "t:schema.templates.index.mint.settings.right_sidebar_width.info"
      },
      {
        "id": "links_html",
        "type": "html",
        "label": "t:schema.templates.index.shared.settings.links_html.label",
        "info": "t:schema.templates.index.shared.settings.links_html.info"
      }
    ]
  }
{% endschema %}
