<!doctype html>
<html lang="{{ site.language }}" class="scroll-smooth" data-theme="light">
  <head>
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="turbo-prefetch" content="false">
    {% meta_tags %}
    {{ 'stylesheets/application.css' | asset_url | stylesheet_tag: data-turbo-track: 'reload' }}
    {{ 'baklib/shared/main.css' | asset_url | stylesheet_tag: data-turbo-track: 'reload' }}
    {{ 'baklib/shared/main.js' | asset_url | script_tag: data-turbo-track: 'reload' }}
    {{ 'javascripts/application.js' | asset_url | script_tag: defer: true, data-turbo-track: 'reload' }}
    {% render 'site_fonts' %}

    <style>
      {%- assign index_page = site.pages['/'] -%}
      {%- assign screen_width = index_page.settings.screen_width.value | presence | default: '1200px' -%}
      {%- assign left_sidebar_width = index_page.settings.left_sidebar_width | presence | default: '400' | append: 'px' -%}
      {%- assign right_sidebar_width = index_page.settings.right_sidebar_width | presence | default: '240' | append: 'px' -%}
      {%- comment -%}
        暂不渲染全站 header/footer 时，将 --header-height 置为 0，避免 Class经典布局侧栏 sticky 仍预留原导航高度。
        恢复页眉页脚后，请改回使用 site.settings.header_height。
      {%- endcomment -%}
      {%- assign header_height = '64px' -%}

      :root {
        --max-content-width: {{ screen_width }};
        --left-sidebar-width: {{ left_sidebar_width }};
        --right-sidebar-width: {{ right_sidebar_width  }};
        --header-height: {{ header_height }};
      }
    </style>

    {% assign head_html = site.settings.head_html | presence %}
    {% if head_html %}
      <!-- start head_html -->
      {{ head_html }}
      <!-- end head_html -->
    {% endif %}

    {% weixin_share_tag app_id: site.settings.weixin_app_id, app_secret: site.settings.weixin_app_secret, debug: site.settings.weixin_debug, enabled: site.settings.weixin_enabled %}
  </head>
  <body id="js--body" class="min-h-screen tracking-wide" x-data="{ isHomePage: false }" x-init="isHomePage = location.pathname === '{{ site.index_path }}'">
    {% comment %} 暂不加载全站 header / footer（各首页变体自建顶栏与页脚时再恢复） {% endcomment %}
    {{ content_for_layout }}
  </body>
</html>
