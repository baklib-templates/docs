        "label": "t:schema.generic.settings.logo_url.label",
        "info": "t:schema.generic.settings.logo_url.info"
      },
      {
        "id": "company_name",
        "label": "t:schema.generic.settings.company_name.label",
        "type": "text",
        "default": "t:schema.generic.settings.company_name.default",
        "info": "t:schema.generic.settings.company_name.info"
      },
      {
        "id": "copyright_info",
        "type": "text",
        "label": "t:schema.generic.settings.copyright_info.label",
        "default": "t:schema.generic.settings.copyright_info.default"
      },
      {
        "id": "ai_search_completed_text",
        "type": "text",
        "label": "t:schema.generic.settings.ai_search_completed_text.label",
        "info": "t:schema.generic.settings.ai_search_completed_text.info"
      },
      {
        "id": "feedback_helper_text",
        "type": "textarea",
        "label": "t:schema.generic.settings.feedback_helper_text.label",
        "rows": 3,
        "info": "t:schema.generic.settings.feedback_helper_text.info",
        "default": "t:schema.generic.settings.feedback_helper_text.default"
      }
    ]
  },
  {
    "name": "t:schema.page_config.name",
    "settings": [
