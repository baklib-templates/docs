        "value": "zh-TW"
      },
      {
        "name": "한국어",
        "value": "ko"
      },
      {
        "name": "English",
        "value": "en"
      },
      {
        "name": "日本語",
        "value": "ja"
      },
      {
        "name": "Deutsch",
        "value": "de"
      },
      {
        "name": "Français",
        "value": "fr"
