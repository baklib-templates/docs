{% layout none %}
{% assign q = params.q | strip %}
{% assign empty_message = "templates.search.no_results" | t: "没有找到相关结果" %}
{% assign featured_label = "templates.search.featured_label" | t: "精选" %}
<turbo-frame id="search_preview_frame">
  {% if q == blank %}
  {% else %}
    {% search site.pages, keywords: q, by_user: true %}
      {% for link in search.extends %}
        <a
          href="{{ link.url }}"
          data-turbo-frame="_top"
          data-search-item
          data-index="{{ idx }}"
          class="search-modal__row group flex w-full min-w-0 items-start gap-2.5 rounded-xl border border-transparent px-2.5 py-2.5 text-left transition-colors hover:bg-base-200/80"
        >
          <span class="mt-0.5 inline-flex size-6 shrink-0 items-center justify-center rounded-md bg-primary/15 text-xs font-bold text-primary" aria-hidden="true">↗</span>
          <span class="min-w-0 flex-1">
            <span class="mb-0.5 line-clamp-1 block text-[0.7rem] font-semibold uppercase tracking-wide text-base-content/45">{{ featured_label }}</span>
            <span class="search-highlight-block line-clamp-2 block text-sm font-semibold leading-snug text-base-content">{{ link.link_text }}</span>
          </span>
          <svg class="search-modal__chev mt-1 size-4 shrink-0 text-base-content/30 opacity-0 transition-opacity group-hover:opacity-100" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="m9 6 6 6-6 6" />
          </svg>
        </a>
      {% endfor %}

      {% paginate_tag search.pages, as: 'items', per: 6, page: 1 %}
        {% for page in items %}
          {% capture bc_joined %}
            {% for crumb in page.breadcrumb %}
              {% unless forloop.first %}
                ›
              {% endunless %}
              {{ crumb.link_text }}
            {% endfor %}
          {% endcapture %}
          <a
            href="{{ page.path }}"
            data-turbo-frame="_top"
            data-search-item
            data-index="{{ idx }}"
            class="search-modal__row group flex w-full min-w-0 items-start gap-2.5 rounded-xl border border-transparent px-2.5 py-2.5 text-left transition-colors hover:bg-base-200/80"
          >
            <span class="mt-0.5 inline-flex size-6 shrink-0 items-center justify-center rounded-md bg-base-200/80 text-xs font-bold text-base-content/50 group-hover:bg-base-300/80" aria-hidden="true">#</span>
            <span class="min-w-0 flex-1">
              {% assign bc_plain = bc_joined | strip %}
              {% if bc_plain != blank %}
                <span class="search-highlight-block mb-0.5 line-clamp-1 block text-[0.7rem] text-base-content/45">{{ bc_plain }}</span>
              {% endif %}
              <span class="search-highlight-block line-clamp-2 block text-sm font-semibold leading-snug text-base-content">{{ page.highlighted_search_title }}</span>
              {% unless page.highlighted_search_content == empty %}
                <span class="search-highlight-block mt-1 line-clamp-2 block text-xs leading-relaxed text-base-content/55">{{ page.highlighted_search_content }}</span>
              {% endunless %}
            </span>
            <svg class="search-modal__chev mt-1 size-4 shrink-0 text-base-content/30 opacity-0 transition-opacity group-hover:opacity-100" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="m9 6 6 6-6 6" />
            </svg>
          </a>
          {% assign idx = idx | plus: 1 %}
        {% else %}
          <div class="rounded-xl border border-dashed border-base-300 bg-base-200/30 px-4 py-8 text-center text-sm text-base-content/60">
            {{ empty_message }}
          </div>
        {% endfor %}
      {% endpaginate_tag %}
    {% endsearch %}
  {% endif %}
</turbo-frame>
