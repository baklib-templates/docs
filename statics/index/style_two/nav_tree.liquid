{% layout none %}

{% assign parent_path = params.parent_path | default: '/' %}
{% assign expand = params.expand | default: false %}
<turbo-frame id="index_style_two_nav_tree_frame_{{ parent_path | replace: '/', '_' }}" class="w-full">
  {% assign root_page = site.pages[parent_path] %}
  {% unless root_page %}
    {% assign root_page = site.pages['/'] %}
  {% endunless %}
  {% assign nav_tree = root_page | nav_tree: 2, include_settings: 'icon' %}
  {% assign depth = params.depth | presence | default: 0 %}
  {% render 'index/style_two/nav_tree',
      nav_tree: nav_tree,
      depth: depth,
      current_path: '',
      parent_path: parent_path,
      expand: expand
  %}
</turbo-frame>
