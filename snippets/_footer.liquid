{% assign footer_menu_html = site.settings.footer_menu_html | presence %}
{% assign company_name = site.settings.company_name | presence | default: site.name %}
{% assign copyright_info = site.settings.copyright_info | presence %}
{% assign year = 'now' | date: '%Y' %}

{% if footer_menu_html %}
  <footer id="footer" class="footer footer-center">
    {{ footer_menu_html }}
  </footer>
{% else %}
  <footer id="footer" class="footer footer-center">
    <div class="p-6">
      <div class="flex flex-wrap items-center justify-center gap-x-3 gap-y-1">
        <span>© {{ year }} {{ company_name }} {{ 'snippets.footer.copyright' | t: '版权所有' }}</span>
        {% if copyright_info %}
          <a href="https://beian.miit.gov.cn/" target="_blank" rel="noopener noreferrer" class="hover:underline">{{ copyright_info }}</a>
        {% endif %}
      </div>
    </div>
  </footer>
{% endif %}
