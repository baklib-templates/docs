{% assign ai_variant = variant | default: 'desktop' %}
{% assign ai_wrapper_class = wrapper_class | default: '' %}
{% assign ai_messages_class = messages_class | default: '' %}

<div
  class="{{ ai_wrapper_class }}"
  data-ai-search-target="messagesScroll"
  data-ai-search-variant="{{ ai_variant }}"
>
  <div class="mint-ai-empty-hint flex h-full items-center justify-center px-4 text-[0.8125rem] leading-relaxed text-base-content/50">
    {{ "ai.disclaimer" | t: "内容由 AI 生成，可能存在错误，请自行核实。" }}
  </div>
  <div
    data-ai-search-target="messages"
    class="{{ ai_messages_class }}"
  ></div>
</div>
