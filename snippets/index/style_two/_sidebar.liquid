{% comment %} Card文档布局左侧栏顶区：Logo、搜索、Ask AI {% endcomment %}
{% assign default_site_icon = 'images/default-site-icon.svg' | asset_url %}

<div class="hidden shrink-0 space-y-3 px-3 pb-4 pt-3 lg:block lg:px-4 lg:pt-4">
  <a href="{{ site.index_path }}" class="flex min-w-0 items-center gap-2 font-semibold tracking-tight text-base-content">
    {% assign logo_url = site.settings.logo_url | presence %}
    {% if logo_url %}
      <span class="inline-flex h-7 max-h-7 shrink-0 items-center justify-center">
        <img src="{{ logo_url }}" class="h-full w-auto max-w-[8rem] rounded-md object-contain" width="128" height="28" alt="{{ site.name | escape_once }}">
      </span>
    {% else %}
      {% assign favicon_url = site.favicon_url | presence | default: default_site_icon %}
      {% if favicon_url %}
        <span class="inline-flex size-10 shrink-0 items-center justify-center overflow-hidden rounded-md bg-base-200" aria-hidden="true">
          <img src="{{ favicon_url }}" class="object-contain" width="20" height="20" alt="">
        </span>
      {% endif %}
      <span class="truncate text-2xl md:text-3l font-bold tracking-tight">{{ site.name }}</span>
    {% endif %}
  </a>

  <div class="flex items-center gap-2">
    <button
      type="button"
      class="flex h-9 min-w-0 flex-1 cursor-pointer items-center rounded-lg border border-base-300/80 bg-white px-2.5 text-left text-[0.85rem] text-base-content/60 transition-colors hover:border-base-content/400"
      data-action="click->header-search#openModal"
      aria-haspopup="dialog"
    >
      <i class="ri-search-line shrink-0 text-[0.95rem] leading-none text-base-content/45" aria-hidden="true"></i>
      <span class="ml-2 min-w-0 flex-1 truncate">{{ 'search.placeholder' | t: '搜索...' }}</span>
      <kbd class="ml-1 hidden shrink-0 text-[0.65rem] font-medium text-base-content/40 sm:inline">⌘K</kbd>
    </button>
    <button
      type="button"
      class="h-9 w-9 min-h-0 shrink-0 border border-base-300/80 bg-white text-primary hover:bg-white hover:border-base-content/400 rounded-lg cursor-pointer"
      @click="toggleAiAssistant()"
      aria-label="{{ 'snippets.header.ask_ai' | t: '问 AI' }}"
    >
      <i class="ri-sparkling-2-line shrink-0 text-[0.95rem] leading-none text-primary" aria-hidden="true"></i>
    </button>
  </div>
</div>
