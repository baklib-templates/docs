{% assign hot_keywords = page.settings.search_hot_keywords | reg_split: "/\n/" %}
{% assign hero_title = page.settings.home_hero_title | presence %}
{% assign hero_desc = page.settings.home_hero_description | presence %}

{% assign home_guide_limit = 3 %}
{% assign show_guide_section = true %}
{% if page.settings.home_show_guide_section == false %}
  {% assign show_guide_section = false %}
{% endif %}
{% assign guide_section_title = page.settings.home_guide_section_title %}
{% assign home_guide_use_fallback = true %}
{% if show_guide_section %}
  {% query home_guide_pages from site.pages %}
    {
      "where": {
        "settings.show_on_home_guide_eq": true
      },
      "limit": {{ home_guide_limit }}
    }
  {% endquery %}
  {% for _guide_probe in home_guide_pages %}
    {% assign home_guide_use_fallback = false %}
    {% break %}
  {% endfor %}
  {% if home_guide_use_fallback %}
    {% assign home_guide_pages = site.pages | order_by: '-visits_count' %}
  {% endif %}
{% endif %}

{% assign show_recommended = page.settings.home_show_recommended %}
{% assign recommended_title = page.settings.home_recommended_title %}
{% assign recommended_limit = 8 %}
{% assign recommended_pages = page.pages | order_by: '-visits_count' | limit: recommended_limit %}

{% assign help_title = page.settings.home_help_title %}
{% assign help_desc = page.settings.home_help_description %}
{% assign first_channel = page.children_in_list | first %}

<div class="mx-auto w-full max-w-5xl px-4 py-12 lg:py-20">
  <div class="mx-auto mb-16 max-w-2xl text-center">
    <h1 class="mb-4 text-4xl font-extrabold tracking-tight text-slate-900">{{ hero_title }}</h1>
    <p class="mb-8 text-base text-slate-500">{{ hero_desc }}</p>

    <div class="group relative">
      <div
        role="button"
        tabindex="0"
        aria-label="{{ 'snippets.style_two.home.search_placeholder' | t: '输入关键词，搜索您需要的指南或文档...' }}"
        class="flex w-full cursor-pointer items-center rounded-xl border border-slate-200 bg-white py-3.5 pl-12 pr-4 text-sm text-slate-400 shadow-sm transition hover:border-slate-300 focus-visible:border-blue-500 focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-blue-50"
        data-action="click->header-search#openModal keydown.enter->header-search#openModal"
      >
        {{ 'snippets.style_two.home.search_placeholder' | t: '输入关键词，搜索您需要的指南或文档...' }}
      </div>
      <i
        class="ri-search-line pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 transition group-focus-within:text-blue-500"
        aria-hidden="true"
      ></i>
    </div>

    {% if hot_keywords.size > 0 %}
      <div class="mt-4 flex flex-wrap items-center justify-center gap-2 text-left">
        <span class="text-sm text-slate-500">{{ 'layout.theme.search_keywords_label' | t: '热门搜索' }}：</span>
        {% for kw in hot_keywords %}
          {% assign kw_trim = kw | strip %}
          {% if kw_trim != blank %}
            <button
              type="button"
              class="rounded-full border border-slate-200 bg-white px-3 py-1 text-xs font-medium text-slate-600 transition hover:border-blue-300 hover:bg-blue-50 hover:text-blue-700"
              data-action="click->header-search#applyHotKeyword"
              data-kw="{{ kw_trim | escape_once }}"
            >
              {{ kw_trim }}
            </button>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </div>

  {% if show_guide_section %}
    <div class="mb-12">
      {% if guide_section_title != blank %}
        <h2 class="mb-6 flex items-center text-xs font-bold tracking-widest text-slate-400">
          <span class="mr-2 h-px w-4 bg-slate-300"></span>
          {{ guide_section_title }}
        </h2>
      {% endif %}
      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        {% assign guide_cards_shown = 0 %}
        {% for card_page in home_guide_pages %}
          {% if guide_cards_shown >= home_guide_limit %}{% break %}{% endif %}
            {% if card_page.full_slug == '/' %}{% continue %}{% endif %}
          {% assign mod = guide_cards_shown | modulo: 3 %}
          {% case mod %}
            {% when 0 %}
              {% assign accent_bg = 'bg-blue-50' %}
              {% assign accent_text = 'text-blue-600' %}
              {% assign fallback_icon = 'ri-flag-line' %}
            {% when 1 %}
              {% assign accent_bg = 'bg-emerald-50' %}
              {% assign accent_text = 'text-emerald-600' %}
              {% assign fallback_icon = 'ri-question-answer-line' %}
            {% else %}
              {% assign accent_bg = 'bg-purple-50' %}
              {% assign accent_text = 'text-purple-600' %}
              {% assign fallback_icon = 'ri-code-line' %}
          {% endcase %}
          {% assign card_desc = card_page.settings.description | presence %}
          {% assign icon_url = card_page.settings.icon | presence %}
          <a
            href="{{ card_page.path }}"
            data-turbo-frame="main-content-frame"
            data-turbo-action="advance"
            class="block rounded-2xl border border-slate-200 bg-white p-6 transition duration-300 hover:-translate-y-1.5 hover:shadow-lg"
          >
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-xl {{ accent_bg }} {{ accent_text }}">
              {% if icon_url %}
                <img src="{{ icon_url }}" alt="" class="size-5 rounded object-cover" width="20" height="20" loading="lazy" decoding="async" />
              {% else %}
                <i class="{{ fallback_icon }} text-lg" aria-hidden="true"></i>
              {% endif %}
            </div>
            <h3 class="mb-2 text-base font-bold text-slate-900">{{ card_page.link_text }}</h3>
            {% if card_desc %}
              <p class="text-xs leading-relaxed text-slate-500">{{ card_desc }}</p>
            {% else %}
              <p class="text-xs leading-relaxed text-slate-500">
                {{ 'snippets.style_two.home.channel_card_fallback_desc' | t: '进入该专题浏览相关文档与说明。' }}
              </p>
            {% endif %}
          </a>
          {% assign guide_cards_shown = guide_cards_shown | plus: 1 %}
        {% endfor %}
      </div>
    </div>
  {% endif %}

  {% if show_recommended %}
    <div class="mb-12">
      <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class="mb-4 flex items-center justify-between">
          <h3 class="flex items-center text-sm font-bold text-slate-900">
            {{ recommended_title }}
          </h3>
          {% if first_channel %}
            <a
              href="{{ first_channel.path }}"
              data-turbo-frame="main-content-frame"
              data-turbo-action="advance"
              class="text-xs text-blue-600 hover:underline"
            >
              {{ 'snippets.style_two.home.view_all' | t: '查看全部' }}
            </a>
          {% else %}
            <span class="text-xs text-blue-600">{{ 'snippets.style_two.home.view_all' | t: '查看全部' }}</span>
          {% endif %}
        </div>
        <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
          {% for doc in recommended_pages %}
            <a
              href="{{ doc.path }}"
              data-turbo-frame="main-content-frame"
              data-turbo-action="advance"
              class="flex items-center justify-between gap-2 rounded-xl bg-slate-50 p-3 transition hover:bg-blue-50/40"
            >
              <div class="flex min-w-0 items-center gap-3">
                <span class="h-1.5 w-1.5 shrink-0 rounded-full bg-blue-600"></span>
                <span class="line-clamp-2 text-xs font-medium text-slate-700">{{ doc.link_text }}</span>
              </div>
              <span class="shrink-0 text-[10px] text-slate-400">
                {% if doc.edited_at %}{{ doc.edited_at | time_ago }}{% else %}{{ 'snippets.style_two.home.tag_tech' | t: '技术推荐' }}{% endif %}
              </span>
            </a>
          {% else %}
            {% render 'index/style_two/home_recommended_defaults' %}
          {% endfor %}
        </div>
      </div>
    </div>
  {% endif %}

  {% if site.settings.feedback_enabled %}
    <section class="relative overflow-hidden rounded-xl border border-slate-800 bg-gradient-to-br from-slate-900 to-slate-800 p-8 text-center text-white shadow-sm">
      <div class="absolute -right-10 -bottom-10 h-40 w-40 rounded-full bg-emerald-500/10 blur-2xl"></div>
      <h3 class="relative z-10 mb-2 text-lg font-bold">{{ help_title }}</h3>
      <p class="relative z-10 mx-auto mb-5 max-w-xl text-xs leading-relaxed text-slate-400">{{ help_desc }}</p>
      <div class="relative z-10 flex justify-center gap-3">
        <button
          type="button"
          class="cursor-pointer rounded-lg bg-emerald-500 px-4 py-1.5 text-xs font-medium text-white shadow-sm shadow-emerald-900/20 transition-colors hover:bg-emerald-600"
          onclick="document.getElementById('home-feedback-modal')?.showModal()"
        >
          {{ 'snippets.home.feedback_btn' | t: '在线反馈' }}
        </button>
      </div>
    </section>
  {% endif %}
</div>

{% if site.settings.feedback_enabled %}
  {% render 'index/home_feedback_modal', page: page %}
{% endif %}
