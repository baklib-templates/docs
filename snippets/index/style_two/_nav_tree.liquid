{%# locals:(nav_tree:, depth: 0, current_path: '', parent_path: '/', tree_url: '', id_prefix: 'index_style_two_nav_tree_frame_', root_container: '.custom-menu', show_method_badges: false, expand: false) %}
{% assign depth = depth | default: 0 %}
{% assign root_container = root_container | default: '.custom-menu' %}
{% assign id_prefix = id_prefix | default: 'index_style_two_nav_tree_frame_' %}
{% assign tree_url = tree_url | default: statics['index/style_two/nav_tree'] %}
{% assign current_path = current_path | default: '' %}
{% assign parent_path = parent_path | default: '/' %}
{% assign expand = expand | default: false %}

<div
  class="style-two-nav-tree min-w-0 w-full max-w-full [&_[turbo-nav-tree-children-container]_ul]:mt-0"
  data-controller="turbo-nav-tree"
  data-turbo-nav-tree-nav-tree-value='{{ nav_tree | to_json | escape }}'
  data-turbo-nav-tree-depth-value='{{ depth }}'
  data-turbo-nav-tree-parent-path-value='{{ parent_path }}'
  data-turbo-nav-tree-current-path-value="{{ current_path }}"
  data-turbo-nav-tree-url-value='{{ tree_url }}'
  data-turbo-nav-tree-id-prefix-value='{{ id_prefix }}'
  data-turbo-nav-tree-root-container-value='{{ root_container }}'
  data-turbo-nav-tree-container-style-value="flex w-full flex-col"
  data-turbo-nav-tree-show-method-badges-value="{% if show_method_badges %}true{% else %}false{% endif %}"
  data-turbo-nav-tree-expand-value="1"
>
  <template data-turbo-nav-tree-target="itemTemplate">
    {% raw %}
      {{#hasChildren}}
      <div
        class="group/menu-row relative scroll-m-4 first:scroll-m-20 flex min-w-0 w-[calc(100%-1rem)] max-w-full items-stretch gap-0.5 border-l border-base-content/5 transition-colors hover:border-base-content/20 [&[active]]:border-primary [&[active]>a]:font-semibold [&[active]>a]:text-primary"
        data-title="{{link_text}}"
      >
        <a
          class="group/minilink flex min-w-0 flex-1 items-start gap-x-3 py-2 pr-3 text-left outline-offset-[-1px] text-base-content/70 hover:text-base-content"
          style="padding-left: calc(1rem + {{depth}} * 0.75rem)"
          href="{{path}}"
          data-turbo-frame="main-content-frame"
          data-turbo-action="advance"
          data-turbo-nav-tree-only-open-param="true"
          data-action="click->turbo-nav-tree#click"
        >
          {{#show_icon_column}}
          <div class="h-[1lh] flex shrink-0 items-center">
            {{#icon_url}}
            <span class="relative inline-flex size-4 shrink-0 items-center justify-center rounded">
              <img src="{{icon_url}}" alt="" class="size-4 rounded object-cover" loading="lazy" decoding="async" onerror="this.classList.add('hidden'); this.nextElementSibling.classList.remove('hidden')" />
              <span class="hidden size-4 shrink-0 rounded" aria-hidden="true"></span>
            </span>
            {{/icon_url}}
            {{^icon_url}}
            <span class="size-4 shrink-0 rounded" aria-hidden="true"></span>
            {{/icon_url}}
          </div>
          {{/show_icon_column}}
          <div class="flex min-w-0 flex-1 items-start gap-x-2.5">
            <span class="line-clamp-1 hyphens-auto break-all">{{link_text}}</span>
          </div>
        </a>
        <button
          type="button"
          class="my-0.5 shrink-0 cursor-pointer px-2 text-base-content/50 hover:border-none hover:bg-transparent group-hover/menu-row:text-base-content"
          data-action="click->turbo-nav-tree#toggle"
          aria-expanded="{{#open}}true{{/open}}{{^open}}false{{/open}}"
        >
          <span turbo-nav-tree-item-target-icon class="inline-flex text-md transition-transform duration-75 {{#open}}rotate-90{{/open}}">
            <i class="ri-arrow-right-s-line leading-none" aria-hidden="true"></i>
          </span>
        </button>
      </div>
      {{/hasChildren}}
      {{^hasChildren}}
      <div
        class="group/menu-row relative scroll-m-4 first:scroll-m-20 min-w-0 w-[calc(100%-1rem)] max-w-full border-l border-base-content/5 transition-colors hover:border-base-content/20 [&[active]]:border-primary [&[active]>a]:font-semibold [&[active]>a]:text-primary"
        data-title="{{link_text}}"
      >
        <a
          class="group flex min-w-0 w-full cursor-pointer items-start gap-x-3 py-2 pr-3 text-left outline-offset-[-1px] text-base-content/70 hover:text-base-content"
          style="padding-left: calc(1rem + {{depth}} * 0.75rem)"
          href="{{path}}"
          data-turbo-frame="main-content-frame"
          data-turbo-action="advance"
          data-action="click->turbo-nav-tree#click"
        >
          {{#show_icon_column}}
          <div class="h-[1lh] flex shrink-0 items-center">
            {{#icon_url}}
            <span class="relative inline-flex size-4 shrink-0 items-center justify-center rounded">
              <img src="{{icon_url}}" alt="" class="size-4 rounded object-cover" loading="lazy" decoding="async" onerror="this.classList.add('hidden'); this.nextElementSibling.classList.remove('hidden')" />
              <span class="hidden size-4 shrink-0 rounded" aria-hidden="true"></span>
            </span>
            {{/icon_url}}
            {{^icon_url}}
            <span class="size-4 shrink-0 rounded" aria-hidden="true"></span>
            {{/icon_url}}
          </div>
          {{/show_icon_column}}
          <div class="flex min-w-0 flex-1 items-start gap-x-2.5">
            <span class="line-clamp-1 hyphens-auto break-all">{{link_text}}</span>
          </div>
        </a>
      </div>
      {{/hasChildren}}
    {% endraw %}
  </template>
</div>
