{% comment %}
  推荐内容列表占位（父级为 space-y-2.5 列表）
  locals: limit (optional, default 3)
{% endcomment %}
{% assign default_limit = limit | default: 3 %}
{% assign default_slots = '1,2,3' | split: ',' %}

{% for _slot in default_slots %}
  {% if forloop.index > default_limit %}{% break %}{% endif %}
  {% assign idx = forloop.index0 %}
  <div class="flex items-center justify-between gap-3 rounded-lg border border-dashed border-base-300/80 bg-base-200/20 p-3" aria-hidden="true">
    <div class="flex min-w-0 items-center gap-3 overflow-hidden">
      <i class="ri-file-text-line size-4 shrink-0 text-base-content/35" aria-hidden="true"></i>
      <span class="truncate text-sm font-medium text-base-content/55">
        {% case idx %}
          {% when 0 %}
            {{ 'snippets.almond.home.rec_default_1' | t: 'Markdown 文档编写语法与排版指南' }}
          {% when 1 %}
            {{ 'snippets.almond.home.rec_default_2' | t: '代码高亮块扩展渲染规范' }}
          {% else %}
            {{ 'snippets.almond.home.rec_default_3' | t: '全局公共嵌入资源白名单' }}
        {% endcase %}
      </span>
    </div>
    <i class="ri-arrow-right-line size-4 shrink-0 text-base-content/25" aria-hidden="true"></i>
  </div>
{% endfor %}
