{% assign index_page = site.pages['/'] %}
{% assign current_root_channel_path = page.breadcrumb[1].path %}
{% assign current_root_channel = site.pages[current_root_channel_path] %}
{% unless current_root_channel %}
  {% assign current_root_channel = index_page.children_in_list | first %}
{% endunless %}
{% assign ai_reading_text = "ai.reading" | t: "正在阅读文档…" | presence %}
{% assign ai_thinking_status = "ai.thinking_status" | t: "正在思考…" | presence %}
{% assign ai_network_error = "ai.network_error" | t: "网络错误，请重试" | presence %}
{% assign ai_timeout_error = "ai.timeout_error" | t: "响应超时，请重试" | presence %}
{% assign ai_copy_success = "ai.copy_success" | t: "已复制" | presence %}
{% assign ai_copy_error = "ai.copy_error" | t: "复制失败" | presence %}
{% assign search_ask_ai_message_tpl = "search.ask_ai_message" | t: "请介绍一下「%{query}」" %}
{% assign ai_completed_text = site.settings.ai_search_completed_text | presence %}
{% unless ai_completed_text %}
  {% assign ai_completed_text = "ai.completed" | t: "AI 回答完毕." | presence %}
{% endunless %}

{% assign screen_width = index_page.settings.screen_width | default: '1280px' %}
{% assign left_sidebar_width = index_page.settings.left_sidebar_width | default: 264 %}

{% comment %} 指定首页路由时，由哪个页面渲染首页内容 {% endcomment %}
{% assign base_page = page %}
{% assign home_page_path = index_page.settings.home_page_path | presence %}
{% if home_page_path and page.full_slug == '/' %}
  {% assign home_page = site.pages[home_page_path] %}
  {% if home_page %}
    {% assign page = home_page %}
  {% endif %}
{% endif %}

<div
  data-controller="header-search ai-search"
  data-action="ai-send@window->ai-search#sendFromWindow"
  data-header-search-search-url-value="{{ site.search_path }}"
  data-header-search-preview-url-value="{{ statics['index/almond/search_preview'] }}"
  data-header-search-ask-ai-message-template-value="{{ search_ask_ai_message_tpl | escape }}"
  data-ai-search-url-value="{{ site.index_path }}-/ai-search-completion"
  data-ai-search-chats-url-value="{{ site.index_path }}-/ai_chats"
  data-ai-search-timeout-value="60"
  data-ai-search-messages-value='{"thinking":"{{ ai_thinking_status | escape }}","reading":"{{ ai_reading_text | escape }}","thinking_status":"{{ ai_thinking_status | escape }}","completed":"{{ ai_completed_text | escape }}","network_error":"{{ ai_network_error | escape }}","timeout_error":"{{ ai_timeout_error | escape }}","copy_success":"{{ ai_copy_success | escape }}","copy_error":"{{ ai_copy_error | escape }}"}'
  data-ai-search-query-value='{"path":"{{ page.path | escape }}"}'
  class="flex min-h-screen flex-grow relative bg-base-200/40 text-base-content"
  style="--max-content-width: {{ screen_width }}; --left-sidebar-width: {{ left_sidebar_width }}px; --header-height: 3.5rem;"
  x-data="{
    isAtBottom: false,
    isAiOpen: localStorage.getItem('almondIsAiOpen') === 'true',
    aiSidebarWidth: 350,
    aiSidebarMinWidth: 350,
    aiSidebarMaxWidth: 600,
    currentPath: '{{ page.path }}',
    indexPath: (() => { let p = '{{ site.index_path }}'; if (p.length > 1 && p.endsWith('/')) p = p.slice(0, -1); return p || '/'; })(),
    channelPathActive(href, index, is_full_match = false) {
      if (index === 1 && this.currentPath === this.indexPath) return true;
      if (!href) return false;
      let normalizedHref = href;
      if (normalizedHref.length > 1 && normalizedHref.endsWith('/')) normalizedHref = normalizedHref.slice(0, -1);
      if (normalizedHref === this.indexPath) return this.currentPath === this.indexPath;
      if (is_full_match) return this.currentPath === normalizedHref;
      return this.currentPath === normalizedHref || (this.currentPath && this.currentPath.startsWith(normalizedHref + '/'));
    },
    onAiSidebarResize(event) {
      const { size, minSize, maxSize } = event.detail || {};
      if (Number.isFinite(size)) this.aiSidebarWidth = size;
      if (Number.isFinite(minSize)) this.aiSidebarMinWidth = minSize;
      if (Number.isFinite(maxSize)) this.aiSidebarMaxWidth = maxSize;
    },
    toggleAiSidebarWidth() {
      const el = this.$refs.aiSidebar;
      if (!el || !window.Stimulus) return;
      const ctrl = window.Stimulus.getControllerForElementAndIdentifier(el, 'resize-bar');
      ctrl?.toggleWidth();
    },
    closeMobileDrawer() {
      const drawer = document.getElementById('my-drawer-3');
      if (drawer) drawer.checked = false;
    },
    toggleAiAssistant() {
      this.isAiOpen = !this.isAiOpen;
    }
  }"
  x-init="
    const syncCurrentPathFromLocation = () => {
      let p = window.location.pathname || '/';
      if (p.length > 1 && p.endsWith('/')) p = p.slice(0, -1);
      currentPath = p;
    };
    syncCurrentPathFromLocation();
    ['turbo:load', 'turbo:render', 'turbo:frame-load'].forEach((ev) => {
      document.addEventListener(ev, syncCurrentPathFromLocation);
    });
    window.addEventListener('popstate', syncCurrentPathFromLocation);

    const lockScroll = () => {
      const mobile = window.matchMedia('(max-width: 1023px)').matches;
      if (mobile && isAiOpen) {
        document.body.style.overflow = 'hidden';
      } else {
        document.body.style.overflow = '';
        document.documentElement.style.overflow = '';
      }
    };
    $watch('isAiOpen', val => {
      localStorage.setItem('almondIsAiOpen', val);
      lockScroll();
    });
    lockScroll();
    window.addEventListener('resize', lockScroll);
  "
  @scroll.window="isAtBottom = (window.scrollY + window.innerHeight >= document.documentElement.scrollHeight - 120)"
  @ai-send.window="isAiOpen = true"
  @ai-close.window="isAiOpen = false"
  @keydown.window="
    if (event.isComposing) return;
    if (event.key !== 'i' && event.key !== 'I') return;
    if (!(event.metaKey || event.ctrlKey)) return;
    if (event.altKey || event.shiftKey) return;
    event.preventDefault();
    toggleAiAssistant();
  "
>
  <div class="flex min-w-0 flex-1 flex-col">
    {% render 'index/almond/header' %}

    <div class="sticky top-[var(--header-height)] z-30 w-full border-b border-base-200 bg-base-100/95 backdrop-blur-sm lg:hidden">
      <div class="mx-auto flex h-12 max-w-[var(--max-content-width)] items-center gap-2 overflow-hidden px-4">
        <label for="my-drawer-3" class="btn btn-ghost btn-sm btn-square shrink-0 text-base-content/60 -ml-1.5" aria-label="{{ 'snippets.almond.nav.open_sidebar' | t: '打开导航菜单' }}">
          <svg class="size-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </label>
        {% render 'index/almond/breadcrumb', breadcrumb: page.breadcrumb %}
      </div>
    </div>

    <div class="drawer lg:drawer-open flex min-h-0 min-w-0 flex-1">
      <input id="my-drawer-3" type="checkbox" class="drawer-toggle" />
      <div class="drawer-side z-50 lg:sticky lg:top-[var(--header-height)] lg:max-h-[calc(100vh-var(--header-height))]">
        <label for="my-drawer-3" aria-label="{{ 'snippets.almond.nav.close_sidebar' | t: '关闭导航菜单' }}" class="drawer-overlay"></label>
        <aside
          class="flex h-full w-[var(--left-sidebar-width)] flex-col border-r border-base-200 bg-base-100 lg:h-[calc(100vh-var(--header-height))] lg:max-h-[calc(100vh-var(--header-height))]"
          @click="
            const a = $event.target.closest('a[href]');
            const href = a?.getAttribute('href');
            if (a && href && href !== '#') closeMobileDrawer();
          "
        >
          {% render 'index/almond/sidebar' %}
          <div class="min-h-0 flex-1 overflow-y-auto px-2 pb-4 lg:px-3">
            {% render 'index/almond/nav_tree_list', current_path: base_page.path %}
          </div>
          {% assign links_html = index_page.settings.links_html | presence %}
          {% if links_html %}
            <div class="shrink-0 space-y-[0.15rem] border-t border-base-200 px-3 py-3 text-[0.85rem]">
              {{ links_html }}
            </div>
          {% endif %}
        </aside>
      </div>

      <div class="drawer-content almond-layout flex min-w-0 flex-1 flex-col min-h-0">
        <div class="mx-auto flex w-full max-w-[var(--max-content-width)] flex-1 flex-col px-2 pb-4 pt-2 lg:px-3 lg:pb-6 lg:pt-3">
          <turbo-frame id="main-content-frame" class="w-full min-w-0" x-init="
            $el.addEventListener('turbo:before-fetch-request', () => {
              $el.scrollTop = 0;
              window.scrollTo({ top: 0, behavior: 'instant' });
            });
          ">
            <div
              class="almond-card group w-full min-w-0 rounded-2xl border border-base-200 bg-base-100 shadow-sm"
              data-controller="toc"
              data-toc-header-selector-value=".js--header"
              data-toc-offset-value="58"
              data-toc-title-value="{{ 'templates.page.page_toc' | t }}"
              data-toc-clipboard-success-value="{{ 'templates.page.copy_success' | t: '链接已复制' }}"
            >
              <div
                class="group grid w-full grid-cols-1 gap-6 p-5 sm:p-6 lg:p-8 transition-all duration-300 max-w-[calc(var(--container-3xl)+15rem)] mx-auto"
                :class="isAiOpen ? 'lg:grid-cols-1' : 'lg:grid-cols-1 lg:group-[.has-toc]:grid-cols-[minmax(0,var(--container-3xl))_minmax(11rem,15rem)]'"
              >
                <main class="min-w-0 flex flex-col">
                  {% if page.path == site.index_path %}
                    {% render 'index/almond/home_content', page: page %}
                  {% else %}
                    {% render 'index/almond/page_content', page: page, current_root_channel: current_root_channel %}
                  {% endif %}

                  {% render 'index/almond/footer' %}
                </main>

                <aside
                  class="print:hidden hidden w-full min-w-0 overflow-y-auto transition-opacity duration-300 max-h-[calc(100vh-var(--header-height)-4rem)] sticky top-4 space-y-3 text-[0.85rem] lg:group-[.has-toc]:block"
                  x-show="!isAiOpen"
                  x-transition:enter="transition ease-out duration-200"
                  x-transition:enter-start="opacity-0"
                  x-transition:enter-end="opacity-100"
                  x-transition:leave="transition ease-in duration-150"
                  x-transition:leave-start="opacity-100"
                  x-transition:leave-end="opacity-0"
                  aria-label="{{ 'templates.page.page_toc' | t }}"
                >
                  <div data-toc-target="menu">
                    <p class="mb-2 flex items-center gap-2 font-bold text-base-content">
                      <svg class="size-4 text-base-content/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zM3.75 12h.007v.008H3.75V12zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm-.375 5.25h.007v.008H3.75v-.008zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
                      </svg>
                      {{ 'templates.page.page_toc' | t }}
                    </p>
                    <div data-toc-target="links"></div>
                  </div>
                </aside>
              </div>
            </div>
          </turbo-frame>
        </div>
      </div>
    </div>
  </div>

  {% render 'index/ai_sidebar' %}
  {% assign hot_keywords = index_page.settings.search_hot_keywords | reg_split: "/\n/" %}
  {% render 'index/almond/search_modal', hot_keywords: hot_keywords %}
</div>
