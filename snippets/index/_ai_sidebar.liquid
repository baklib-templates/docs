{% comment %} AI Assistant 移动端弹出层 {% endcomment %}
<div class="fixed inset-0 z-[120] lg:hidden overscroll-none" x-show="isAiOpen"
  x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0"
  x-transition:enter-end="opacity-100" x-transition:leave="transition ease-in duration-200"
  x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0" style="display: none;">
  <div class="absolute inset-0 bg-black/40 touch-none" @click="isAiOpen = false" @touchmove.prevent></div>
  <div
    class="absolute inset-x-0 bottom-0 h-[86vh] rounded-t-2xl bg-base-100 shadow-2xl flex flex-col overflow-hidden touch-pan-y">
    <div x-data="{ touchStartY: 0, dragY: 0, dragging: false }" class="touch-none shrink-0"
      @touchstart.passive="touchStartY = $event.touches[0].clientY; dragging = true"
      @touchmove="if (!dragging) return; let moved = $event.touches[0].clientY - touchStartY; dragY = moved > 0 ? moved : 0; $event.preventDefault(); $el.parentElement.style.transform = `translateY(${dragY}px)`; $el.parentElement.style.transition = 'none';"
      @touchend="if (dragY > 120) { isAiOpen = false }; dragging = false; dragY = 0; $el.parentElement.style.transform = ''; $el.parentElement.style.transition = 'transform 0.2s ease-out';"
      @touchcancel="dragging = false; dragY = 0; $el.parentElement.style.transform = ''; $el.parentElement.style.transition = 'transform 0.2s ease-out';">
      <div class="flex items-center justify-center pt-2 pb-1">
        <div class="h-1 w-10 rounded-full bg-base-300"></div>
      </div>
      <div class="flex items-center justify-between px-4 py-3">
        <div class="flex items-center gap-2 font-bold text-base-content text-[0.95rem]">
          <i class="ri-sparkling-2-line size-4 text-primary leading-none" aria-hidden="true"></i>
          {{ "snippets.ai.assistant_title" | t: "AI 助手" }}
        </div>
        <button type="button" class="btn btn-ghost btn-sm btn-square text-base-content/60" aria-label="Close"
          @click="isAiOpen = false">
          <i class="ri-close-line icon-thin text-base text-base-content/60 group-hover:text-base-content leading-none" aria-hidden="true"></i>
        </button>
      </div>
    </div>
    {% render 'index/ai_chat_messages',
      variant: 'drawer',
      wrapper_class: 'flex-1 min-h-0 overflow-y-auto px-4 pb-2',
      messages_class: 'flex flex-col gap-3'
    %}
    <div class="px-4 pb-4 shrink-0">
      <div
        class="flex flex-col w-full rounded-2xl bg-base-100 border border-base-200 focus-within:border-primary transition-colors">
        <div class="relative flex items-end">
          <textarea
            data-ai-search-target="input"
            data-action="input->ai-search#syncSendButton keydown->ai-search#onInputKeydown"
            class="w-full bg-transparent border-0 text-base-content placeholder-base-content/50 focus:outline-none focus:ring-0 py-2.5 pl-3.5 pr-10 text-[0.85rem] !pb-0 resize-none"
            placeholder="{{ ai_input_placeholder }}" style="height: 50px;"></textarea>
        </div>
        <div class="flex items-center justify-between px-2 pb-2">
          <button type="button" class="btn btn-ghost btn-sm btn-square text-base-content/60"
            aria-label="Add attachment">
            <i class="ri-attachment-line leading-none" aria-hidden="true"></i>
          </button>
          <button class="btn btn-circle btn-ghost btn-sm bg-primary/10 text-primary"
            data-ai-search-target="send"
            data-action="click->ai-search#send"
            aria-label="{{ "snippets.ai.send" | t: "发送" }}" disabled>
            <i class="ri-arrow-up-line leading-none" aria-hidden="true"></i>
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

{% comment %} AI Assistant 侧边栏（桌面） {% endcomment %}
<div
  class="hidden lg:flex bg-base-200 overflow-hidden z-50 w-[var(--ai-sidebar-width,340px)] sticky top-0 max-h-screen overflow-y-auto transition-[width] duration-300 [.resize-bar-dragging_&]:transition-none"
  x-show="isAiOpen"
  x-transition:enter="transition ease-out duration-300"
  x-transition:enter-start="opacity-0 translate-x-full"
  x-transition:enter-end="opacity-100 translate-x-0"
  x-transition:leave="transition ease-in duration-300"
  x-transition:leave-start="opacity-100 translate-x-0"
  x-transition:leave-end="opacity-0 translate-x-full"
  style="display: none;"
  x-ref="aiSidebar"
  @resize-bar:resize="onAiSidebarResize($event)"
  data-controller="resize-bar"
  data-resize-bar-target="target"
  data-resize-bar-dragging-class="bg-base-300 cursor-ew-resize !transition-none"
  data-resize-bar-min-size-value="350"
  data-resize-bar-max-size-value="600"
  data-resize-bar-direction-value="left"
  data-resize-bar-remember-value="true"
  data-resize-bar-key-value="ai-sidebar-width"
  data-resize-bar-css-var-value="--ai-sidebar-width">
  <div class="transition bg-base-200 w-[6px] shrink-0 hover:bg-base-300 hover:cursor-ew-resize"
    data-resize-bar-target="bar">
  </div>
  <div
    class="relative flex flex-col flex-1 bg-base-100 min-w-0 min-h-0"
    data-controller="ai-pip"
    data-ai-pip-unsupported-message-value="{{ 'snippets.ai.pop_out_unsupported' | t: '当前浏览器不支持独立窗口' | escape }}"
    data-ai-pip-pop-out-label-value="{{ 'snippets.ai.pop_out_window' | t: '独立窗口' | escape }}"
    data-ai-pip-dock-label-value="{{ 'snippets.ai.dock_to_sidebar' | t: '收回侧边栏' | escape }}"
  >
    <div
      data-ai-pip-target="placeholder"
      class="hidden flex-1 flex-col items-center justify-center gap-3 px-6 text-center text-[0.8125rem] text-base-content/60"
    >
      <i class="ri-picture-in-picture-2-line text-2xl text-primary/80 leading-none" aria-hidden="true"></i>
      <p>{{ "snippets.ai.pip_active" | t: "AI 助手已在独立窗口中打开" }}</p>
      <button
        type="button"
        class="btn btn-outline btn-sm"
        data-action="click->ai-pip#dock"
      >
        {{ "snippets.ai.dock_to_sidebar" | t: "收回侧边栏" }}
      </button>
    </div>

    <div data-ai-pip-target="panel" class="flex min-h-0 flex-1 flex-col">
      <!-- AI Header -->
      <div class="flex items-center justify-between px-4 py-3 border-b border-base-200 shrink-0">
        <div class="flex items-center gap-2 font-bold text-base-content text-[0.95rem]">
          <i class="ri-sparkling-2-line size-4 text-primary leading-none" aria-hidden="true"></i>
          {{ "snippets.ai.assistant_title" | t: "AI 助手" }}
        </div>
        <div class="flex items-center gap-1">
          <button
            type="button"
            class="btn btn-ghost font-normal btn-sm btn-square group hidden"
            data-ai-pip-target="openButton"
            data-action="click->ai-pip#open"
            aria-label="{{ 'snippets.ai.pop_out_window' | t: '独立窗口' }}"
          >
            <i class="ri-picture-in-picture-2-line icon-thin text-base text-base-content/60 group-hover:text-base-content leading-none" aria-hidden="true"></i>
          </button>
          {% comment %} 最大化/最小化， icon 也自动切换 {% endcomment %}
          <button type="button" class="btn btn-ghost font-normal btn-sm btn-square group"
            :aria-label="aiSidebarWidth >= aiSidebarMaxWidth ? 'Collapse' : 'Expand'"
            @click="toggleAiSidebarWidth()">
            <i class="icon-thin text-base text-base-content/60 group-hover:text-base-content leading-none"
              :class="aiSidebarWidth >= aiSidebarMaxWidth ? 'ri-collapse-diagonal-line' : 'ri-expand-diagonal-line'"
              aria-hidden="true"></i>
          </button>
          <button type="button" class="hidden btn btn-ghost font-normal btn-sm btn-square group"
            aria-label="{{ 'snippets.ai.clear_chat' | t: '清空对话' }}"
            data-ai-search-target="clearButton"
            data-action="click->ai-search#clearChat">
            <i class="ri-delete-bin-line icon-thin text-base text-base-content/60 group-hover:text-base-content leading-none" aria-hidden="true"></i>
          </button>
          <div type="button" class="btn btn-ghost font-normal btn-sm btn-square group"
            aria-label="Close" @click="isAiOpen = false">
            <i class="ri-close-line icon-thin text-base text-base-content/60 group-hover:text-base-content leading-none" aria-hidden="true"></i>
          </div>
        </div>
      </div>

      <!-- AI Messages Area -->
      {% render 'index/ai_chat_messages',
        variant: 'desktop',
        wrapper_class: 'flex-1 min-h-0 overflow-y-auto px-5',
        messages_class: 'flex flex-col gap-3 py-4'
      %}

      <!-- AI Input Area -->
      <div class="px-4 pb-4 shrink-0 mt-2">
        <div
          class="flex flex-col w-full rounded-2xl pointer-events-auto bg-base-100 border border-base-200 focus-within:border-primary transition-colors">
          <div class="relative flex items-end">
            <textarea
              data-ai-search-target="input"
              data-action="input->ai-search#syncSendButton keydown->ai-search#onInputKeydown"
              class="w-full bg-transparent border-0 text-base-content placeholder-base-content/50 focus:outline-none focus:ring-0 py-2.5 pl-3.5 pr-10 text-[0.85rem] !pb-0 resize-none"
              placeholder="{{ "snippets.ai.input_placeholder" | t: "输入你的问题…" }}" style="height: 50px;"></textarea>
          </div>
          <div class="flex items-center justify-between px-2 pb-2">
            {% if false %}
              <input type="file" class="hidden">
              <button type="button"
                class="btn btn-ghost btn-sm btn-square text-base-content/60 hover:text-base-content"
                aria-label="Add attachment">
                <i class="ri-attachment-line leading-none" aria-hidden="true"></i>
              </button>
            {% endif %}
            <span class="flex-1"></span>
            <button
              class="btn btn-circle btn-ghost btn-sm bg-primary/10 text-primary"
              data-ai-search-target="send"
              data-action="click->ai-search#send"
              aria-label="{{ "snippets.ai.send" | t: "发送" }}" disabled>
              <i class="ri-arrow-up-line leading-none" aria-hidden="true"></i>
            </button>
          </div>
        </div>
      </div>
    </div>

    <template data-ai-pip-target="shellTemplate">
      <div class="flex h-screen flex-col bg-base-100 text-base-content" data-controller="ai-search">
        <div class="flex shrink-0 items-center justify-between border-b border-base-200 px-4 py-3">
          <div class="flex items-center gap-2 font-bold text-base-content text-[0.95rem]">
            <i class="ri-sparkling-2-line size-4 text-primary leading-none" aria-hidden="true"></i>
            {{ "snippets.ai.assistant_title" | t: "AI 助手" }}
          </div>
          <button
            type="button"
            class="btn btn-ghost btn-sm btn-square text-base-content/60"
            data-ai-pip-dock
            aria-label="{{ 'snippets.ai.dock_to_sidebar' | t: '收回侧边栏' }}"
          >
            <i class="ri-layout-left-line icon-thin text-base leading-none" aria-hidden="true"></i>
          </button>
        </div>
        {% render 'index/ai_chat_messages',
          variant: 'pip',
          wrapper_class: 'flex-1 min-h-0 overflow-y-auto px-4',
          messages_class: 'flex flex-col gap-3 py-4'
        %}
        <div class="shrink-0 px-4 pb-4">
          <div class="flex flex-col w-full rounded-2xl bg-base-100 border border-base-200 focus-within:border-primary transition-colors">
            <div class="relative flex items-end">
              <textarea
                data-ai-search-target="input"
                data-action="input->ai-search#syncSendButton keydown->ai-search#onInputKeydown"
                class="w-full bg-transparent border-0 text-base-content placeholder-base-content/50 focus:outline-none focus:ring-0 py-2.5 pl-3.5 pr-10 text-[0.85rem] !pb-0 resize-none"
                placeholder="{{ "snippets.ai.input_placeholder" | t: "输入你的问题…" }}"
                style="height: 50px;"
              ></textarea>
            </div>
            <div class="flex items-center justify-between px-2 pb-2">
              <button
                class="btn btn-circle btn-ghost btn-sm bg-primary/10 text-primary"
                data-ai-search-target="send"
                data-action="click->ai-search#send"
                aria-label="{{ "snippets.ai.send" | t: "发送" }}"
                disabled
              >
                <i class="ri-arrow-up-line leading-none" aria-hidden="true"></i>
              </button>
            </div>
          </div>
        </div>
        <template data-ai-search-target="userMessageTemplate">
          <div class="ai-chat-user-round flex justify-end">
            <div class="max-w-[88%] rounded-2xl bg-base-200 px-3 py-2">
              <p class="ai-user-message break-words text-[0.875rem] leading-[1.65] text-base-content"></p>
            </div>
          </div>
        </template>
        <template data-ai-search-target="assistantMessageTemplate">
          <div class="ai-chat-assistant-round flex flex-col gap-1">
            <div
              class="w-full rounded-2xl border border-base-200 bg-base-100 px-3 py-2"
              data-controller="markdown"
            >
              <pre class="hidden" data-markdown-target="content"></pre>
              <div class="chat-message max-w-none break-words text-base-content" data-markdown-target="renderedContent"></div>
            </div>
            <div class="ai-message-actions hidden items-center gap-1">
              <button
                class="btn btn-ghost btn-sm btn-square text-base-content/60 hover:text-base-content"
                type="button"
                data-action="click->ai-search#copyResponse"
                aria-label="{{ "snippets.ai.copy_response" | t: "复制回答" }}"
              >
                <i class="ri-file-copy-line leading-none" aria-hidden="true"></i>
              </button>
              <button
                class="btn btn-ghost btn-sm btn-square text-base-content/60 hover:text-base-content"
                type="button"
                data-action="click->ai-search#retryLastResponse"
                aria-label="{{ 'snippets.ai.retry_response' | t: '重新生成' }}"
              >
                <i class="ri-refresh-line leading-none" aria-hidden="true"></i>
              </button>
            </div>
          </div>
        </template>
        <button
          type="button"
          class="hidden btn btn-ghost btn-xs btn-square align-middle text-base-content/70"
          data-ai-search-target="retryButton"
          data-action="click->ai-search#retryFromButton"
          aria-label="{{ 'snippets.ai.retry_response' | t: '重新生成' }}"
        >
          <i class="ri-refresh-line leading-none" aria-hidden="true"></i>
        </button>
        <div data-ai-search-target="error" class="hidden"></div>
      </div>
    </template>
  </div>
</div>

<template data-ai-search-target="userMessageTemplate">
  <div class="ai-chat-user-round flex justify-end">
    <div class="max-w-[88%] rounded-2xl bg-base-200 px-3 py-2">
      <p class="ai-user-message break-words text-[0.875rem] leading-[1.65] text-base-content"></p>
    </div>
  </div>
</template>

<template data-ai-search-target="assistantMessageTemplate">
  <div class="ai-chat-assistant-round flex flex-col gap-1">
    <div
      class="w-full rounded-2xl border border-base-200 bg-base-100 px-3 py-2"
      data-controller="markdown"
    >
      <pre class="hidden" data-markdown-target="content"></pre>
      <div class="chat-message max-w-none break-words text-base-content" data-markdown-target="renderedContent"></div>
    </div>
    <div class="ai-message-actions hidden items-center gap-1">
      <button
        class="btn btn-ghost btn-sm btn-square text-base-content/60 hover:text-base-content"
        type="button"
        data-action="click->ai-search#copyResponse"
        aria-label="{{ "snippets.ai.copy_response" | t: "复制回答" }}"
      >
        <i class="ri-file-copy-line leading-none" aria-hidden="true"></i>
      </button>
      <button
        class="btn btn-ghost btn-sm btn-square text-base-content/60 hover:text-base-content"
        type="button"
        data-action="click->ai-search#retryLastResponse"
        aria-label="{{ 'snippets.ai.retry_response' | t: '重新生成' }}"
      >
        <i class="ri-refresh-line leading-none" aria-hidden="true"></i>
      </button>
    </div>
  </div>
</template>

<button
  type="button"
  class="hidden btn btn-ghost btn-xs btn-square align-middle text-base-content/70"
  data-ai-search-target="retryButton"
  data-action="click->ai-search#retryFromButton"
  aria-label="{{ 'snippets.ai.retry_response' | t: '重新生成' }}"
>
  <i class="ri-refresh-line leading-none" aria-hidden="true"></i>
</button>
<div data-ai-search-target="error" class="hidden"></div>
