{% comment %} locals: hot_keywords {% endcomment %}
{% assign search_ask_ai_section = "snippets.style_one.search.ask_ai_section" | t: "向 AI 助手提问" %}
{% assign search_ask_ai_lead = "snippets.style_one.search.ask_ai_lead" | t: "帮我介绍一下" %}
{% assign search_ask_ai_ellipsis = "snippets.style_one.search.ask_ai_ellipsis" | t: "…" %}
{% assign search_ask_ai_trailing = "snippets.style_one.search.ask_ai_trailing" | t: "" %}
{% assign search_ask_ai_query_display = "snippets.style_one.search.ask_ai_query_display" | t: "「%{query}」" %}
<dialog
  id="site-search-modal"
  class="modal"
  data-header-search-target="modal"
  aria-label="{{ 'search.placeholder' | t: '搜索...' }}"
>
  <div
    class="modal-box flex max-h-[min(85vh,720px)] w-[min(100vw-1rem,36rem)] max-w-none flex-col gap-0 overflow-hidden rounded-2xl border border-base-200 bg-base-100 p-0 shadow-2xl sm:max-w-[min(100vw-2rem,36rem)] fixed top-[5vh] left-1/2 -translate-x-1/2"
  >
    <div class="shrink-0 border-b border-base-200 bg-base-100 px-3 py-3 sm:px-4">
      <label class="border border-base-300 flex h-11 w-full items-center gap-2 rounded-xl bg-base-100 px-3 text-base-content focus-within:border-base-content">
        <i class="ri-search-line shrink-0 text-lg leading-none text-base-content/45" aria-hidden="true"></i>
        <input
          type="search"
          autocomplete="off"
          class="grow truncate border-0 bg-transparent p-0 text-sm outline-none focus:outline-none "
          placeholder="{{ 'search.placeholder' | t: '搜索...' }}"
          data-header-search-target="modalInput"
          data-action="input->header-search#onModalInput keydown->header-search#onModalKeydown"
        />
        <kbd class="">{{ 'search.esc_key' | t: 'ESC' }}</kbd>
      </label>
    </div>

    <div
      class="min-h-20 flex-1 overflow-y-auto overscroll-contain px-3 pb-3 pt-2 sm:px-4 hidden"
      data-header-search-target="resultsScroll"
      data-action="mouseleave->header-search#clearListSelection mouseenter->header-search#resultsEnter"
    >
      <div
        class="mb-1 flex flex-col gap-2 {% unless hot_keywords.size > 0 %}hidden{% endunless %}"
        data-header-search-target="hotSection"
      >
        {% if hot_keywords.size > 0 %}
          <p class="px-0.5 text-[0.7rem] font-semibold uppercase tracking-wide text-base-content/45">
            {{ 'layout.theme.search_keywords_label' | t: '热门搜索' }}
          </p>
          <div class="flex flex-wrap gap-2" data-header-search-target="hotList">
            {% for kw in hot_keywords %}
              {% assign kw_trim = kw | strip %}
              {% if kw_trim != blank %}
                <button
                  type="button"
                  class="btn btn-sm rounded-full border border-base-200 bg-base-200/40 font-normal text-base-content/80 hover:border-primary/30 hover:bg-primary/10"
                  data-action="click->header-search#applyHotKeyword"
                  data-kw="{{ kw_trim | escape_once }}"
                >
                  {{ kw_trim }}
                </button>
              {% endif %}
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <turbo-frame
        id="search_preview_frame"
        class="flex min-h-20 flex-col gap-0"
        data-turbo-action="advance"
        data-header-search-target="previewFrame"
      >
        <div class="flex items-center justify-center h-12 text-base-content/60">
          <div class="loading loading-spinner loading-lg"></div>
        </div>
      </turbo-frame>
    </div>

    <div
      class="shrink-0 border-t border-base-200 bg-base-100 px-3 py-3 sm:px-4 hidden"
      data-header-search-target="aiSection"
    >
      <p class="mb-1.5 px-0.5 text-[0.7rem] font-semibold uppercase tracking-wide text-base-content/45">{{ search_ask_ai_section }}</p>
      <button
        type="button"
        class="flex w-full gap-2.5 rounded-xl px-2 py-2 text-left text-sm text-primary hover:bg-primary/10 items-center bg-base-200/40 cursor-pointer"
        data-header-search-target="aiLink"
        data-header-search-ask-ai-ellipsis-value="{{ search_ask_ai_ellipsis | escape }}"
        data-header-search-ask-ai-query-display-value="{{ search_ask_ai_query_display | escape }}"
        data-action="click->header-search#askAiFromSearch"
      >
        <i class="ri-sparkling-2-line size-4 shrink-0 text-primary leading-none" aria-hidden="true"></i>
        <span class="min-w-0 leading-snug">
          <span class="search-modal-ai-lead text-base-content/70">{{ search_ask_ai_lead }}</span>
          <strong class="search-modal-ai-q font-semibold text-primary"></strong>
          {% if search_ask_ai_trailing != blank %}
            <span class="search-modal-ai-trailing text-base-content/70">{{ search_ask_ai_trailing }}</span>
          {% endif %}
        </span>
      </button>
    </div>
  </div>
  {% comment %} DaisyUI：method="dialog" 的 backdrop 表单，点击遮罩关闭（与官方示例一致）{% endcomment %}
  <form method="dialog" class="modal-backdrop">
    <button>{{ 'generic.buttons.close' | t: '关闭' }}</button>
  </form>
</dialog>
