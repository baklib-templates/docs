{%# locals: (page:) %}

{% assign count = page.children_in_list | size %}
{% if count > 1 %}
  {% assign parent_path = page.path %}
  <turbo-frame class='w-full' id="index_mint_nav_tree_frame_{{ parent_path | replace: '/', '_' }}" src="{{ statics['index/mint/nav_tree'] }}?parent_path={{ parent_path }}" loading="lazy">
    <div class="flex items-center justify-center h-20 text-base-content/60 bg-none">
      <span class="loading loading-spinner loading-md"></span>
    </div>
  </turbo-frame>
{% else %}
  {% assign data = page | nav_tree: 2 %}
  {% render 'index/mint/nav_tree', nav_tree: data %}
{% endif %}