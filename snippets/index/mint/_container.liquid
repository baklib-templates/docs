{% assign index_page = site.pages['/'] %}
{% assign current_root_channel_path = page.breadcrumb[1].path %}
{% assign current_root_channel = site.pages[current_root_channel_path] %}
{% unless current_root_channel %}
  {% assign current_root_channel = index_page.children_in_list | first %}
{% endunless %}

<div class="flex flex-grow relative bg-white text-neutral-900"
  x-data="{
    docTab: 'guides',
    isAtBottom: false,
    isAiOpen: localStorage.getItem('mintIsAiOpen') === 'true',
    currentPath: '{{ page.path }}',
    channelPathActive(href, index) {
      if (index === 1 && this.currentPath == '/') return true;
      if (!href) return false;
      if (href === '/') return this.currentPath === '/';
      return this.currentPath === href || (this.currentPath && this.currentPath.startsWith(href + '/'));
    }
  }"
  x-init="
    const lockScroll = () => {
      const mobile = window.matchMedia('(max-width: 1023px)').matches;
      if (mobile && isAiOpen) {
        document.body.style.overflow = 'hidden';

      } else {
        document.body.style.overflow = '';
        document.documentElement.style.overflow = '';
      }
    };
    $watch('isAiOpen', val => {
      localStorage.setItem('mintIsAiOpen', val);
      lockScroll();
    });
    lockScroll();
    window.addEventListener('resize', lockScroll);
  "
  @scroll.window="isAtBottom = (window.scrollY + window.innerHeight >= document.documentElement.scrollHeight - 120)"
>
  <div class="flex-grow min-w-0">
    {%comment %} Mint 文档顶栏：与天蓝色文档风统一； {% endcomment %}
    {% render 'index/mint/header', page: page %}

    {% comment %} top channels {% endcomment %}
    <div class="sticky top-[var(--header-height)] w-full bg-white z-30 border-b border-neutral-100">
      <div class="mx-auto max-w-[var(--max-content-width)] h-12 px-4 lg:px-6">
        {% comment %} 面包屑 {% endcomment %}
        <div class="h-full flex items-center space-x-2 lg:hidden overflow-hidden">
          <label for="my-drawer-3" class="btn btn-ghost btn-sm btn-square text-neutral-500" aria-label="Open sidebar">
            <svg class="size-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </label>

          {% render 'index/mint/breadcrumb', breadcrumb: page.breadcrumb %}
        </div>

        {% comment %} channels {% endcomment %}
        <div class="hidden lg:flex h-full gap-4 text-[0.85rem] font-bold dark:border-neutral-800 overflow-x-auto overflow-y-hidden" x-cloak>
          {% assign channels = index_page.children_in_list %}
          {% for channel in channels %}
            <a href="{{ channel.path }}"
              class="flex items-center whitespace-nowrap transition-all duration-300 border-b-[3px] space-x-1"
              :class="channelPathActive('{{ channel.path }}', {{ forloop.index }}) ? ' border-emerald-500 text-emerald-600 ' : 'border-transparent text-neutral-500 hover:text-neutral-800'">
              {% if channel.settings.icon %}
                <img src="{{ channel.settings.icon }}" class="size-4" alt="{{ channel.link_text }}">
              {% endif %}
              <span>{{ channel.link_text }}</span>
            </a>
          {% endfor %}
        </div>
      </div>
    </div>

    <div class="drawer lg:drawer-open mx-auto max-w-[var(--max-content-width)]  px-6">
      <input id="my-drawer-3" type="checkbox" class="drawer-toggle" />
      <div
        class="drawer-side lg:sticky lg:top-[calc(var(--header-height)+3.2rem)] lg:max-h-[calc(100vh-var(--header-height)-13.1rem)] lg:overflow-y-auto z-99">
        <label for="my-drawer-3" aria-label="close sidebar" class="drawer-overlay"></label>
        <aside class="px-4 p-4 md:pt-10 pb-12 md:p-0 w-[var(--left-sidebar-width)] bg-white h-full space-y-3">
          {% comment %} index 中配置的链接 {% endcomment %}
          {% assign links_html = index_page.settings.links_html | presence %}
          {% if links_html %}
            <div class="space-y-[0.15rem] text-[0.85rem] -mt-2 pl-0">
              {{ links_html }}
            </div>
          {% endif %}
          {% if false %}
            <a href="#"
              class="flex items-center gap-2 rounded-lg px-2 py-1.5 font-bold text-neutral-600 hover:bg-neutral-100">
              <svg class="size-[1.1rem] text-neutral-400 dark:text-neutral-500" fill="none" viewBox="0 0 24 24"
                stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round"
                  d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
              </svg>
              Documentation
            </a>
          {% endif %}

          {% render 'index/mint/nav_tree_list', page: current_root_channel %}
        </aside>
      </div>

      <div class="drawer-content flex flex-col items-center justify-center">
        <turbo-frame id="main-content-frame" class='w-full' x-init="
                               $el.addEventListener('turbo:before-fetch-request', () => {
                                 $el.scrollTop = 0
                                 window.scrollTo({ top: 0, behavior: 'instant' })
                               })
                             ">
          <div
            data-controller="toc"
            data-toc-header-selector-value=".js--header"
            data-toc-offset-value="58"
            data-toc-title-value="{{ 'templates.page.page_toc' | t }}"
            data-toc-clipboard-success-value="{{ 'templates.page.copy_success' | t: '链接已复制' }}"
            class="w-full min-w-0 group"
          >
            <div class="grid grid-cols-1 gap-6 transition-all duration-300 px-4 lg:px-6 w-full"
              :class="isAiOpen ? 'lg:grid-cols-1' : 'lg:grid-cols-1 lg:group-[.has-toc]:grid-cols-[minmax(0,1fr)_minmax(11rem,15rem)]'">
              {% comment %} 主内容 {% endcomment %}
              <main class="min-w-0 flex flex-col">
                <article class="max-w-none flex flex-1 flex-col pt-10 min-h-[70vh]">
                  <div class="min-h-0 w-full flex-1 flex flex-col">
                    <div class="flex-1">
                      <p class="mb-2 text-[0.8rem] font-bold tracking-wide text-emerald-600 dark:text-emerald-400 uppercase">{{
                        current_root_channel.link_text }}
                      </p>
                      {% # 标题 %}
                      {% assign title = page.link_text | presence %}
                      <div class="mb-4 py-1 flex items-start justify-between gap-3">
                        <h1 class="mb-3 text-2xl sm:text-3xl font-bold tracking-tight text-neutral-900 ">
                          {{ title }}
                        </h1>
                        {% if site.settings.show_page_tools_dropdown %}
                        {% render 'page_tools_dropdown', page: page %}
                        {% endif %}
                      </div>

                      {% if page.settings.description %}
                      <p class="mb-8 text-[1.05rem] text-neutral-500 dark:text-neutral-400">{{ page.settings.description }}</p>
                      {% endif %}

                      {% comment %} page content：TOC 仅扫描正文内标题 {% endcomment %}
                      <div class="prose dark:prose-invert max-w-none min-h-[40vh]" data-toc-target="content">
                        {{ page.settings.content }}
                      </div>
                    </div>

                    {% comment %} 是否有帮助的反馈区域 {% endcomment %}
                    {% if site.settings.feedback_enabled %}
                      {% render 'index/mint/page_feedback', page: page %}
                    {% endif %}

                    {% comment %} 上一页、下一页 {% endcomment %}
                    {% render 'index/mint/page_pager', page: page %}
                  </div>

                  {% comment %} AI：flex-1 在短页占满剩余高度，条在 article 底；长页仍在正文后 + sticky bottom 吸附视口 {% endcomment %}
                  <div class="sticky bottom-5 z-20 mt-6 w-full shrink-0 pointer-events-none print:hidden transition-all duration-300"
                    :class="(isAtBottom || isAiOpen) ? 'translate-y-full opacity-0' : 'translate-y-0 opacity-100'">
                    <div
                      class="pointer-events-auto flex flex-col w-full rounded-2xl border border-neutral-200 bg-white/90 shadow-[0_4px_12px_rgba(0,0,0,0.03)] backdrop-blur-xl transition-colors focus-within:border-emerald-500 dark:border-neutral-700/80 dark:bg-neutral-900/90 dark:focus-within:border-emerald-400">
                      <div class="relative flex items-end">
                        <textarea aria-label="Ask a question..." placeholder="Ask a question..."
                          class="w-full resize-none border-0 bg-transparent py-4 pl-4 pr-14 text-[0.95rem] text-neutral-900 placeholder-neutral-400 focus:outline-none focus:ring-0 dark:text-neutral-100 dark:placeholder-neutral-500"
                          style="height: 60px;"
                          @keydown.enter.prevent="if($el.value.trim()) { isAiOpen = true; $el.value = ''; }"></textarea>
                        <span
                          class="absolute bottom-4 right-12 hidden text-[0.75rem] font-medium text-neutral-400 dark:text-neutral-500 sm:inline">⌘I</span>
                        <button type="button" @click="isAiOpen = true"
                          class="absolute bottom-3 right-2.5 flex size-8 items-center justify-center rounded-lg bg-emerald-500 text-white transition-colors hover:bg-emerald-600 disabled:opacity-50"
                          aria-label="Send message">
                          <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                            stroke-linecap="round" stroke-linejoin="round">
                            <path d="M4.5 10.5L12 3m0 0l7.5 7.5M12 3v18" />
                          </svg>
                        </button>
                      </div>
                    </div>
                  </div>
                </article>

                <footer
                  class="border-t border-neutral-200 py-8 text-[0.85rem] text-neutral-500 dark:border-neutral-800 dark:text-neutral-400">
                  <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
                    <p>© {{ 'now' | date: "%Y" }} Mint Starter Kit. All rights reserved.</p>
                    <div class="flex gap-4">
                      <a href="#" class="hover:text-neutral-900 dark:hover:text-neutral-100">Privacy Policy</a>
                      <a href="#" class="hover:text-neutral-900 dark:hover:text-neutral-100">Terms of Service</a>
                    </div>
                  </div>
                </footer>
              </main>

              {% comment %} 右侧目录：lg+ 且有标题时显示；AI 侧栏打开时关闭 {% endcomment %}
              <aside
                class="print:hidden hidden w-full min-w-0 overflow-y-auto transition-opacity duration-300 max-h-[calc(100vh-var(--header-height)-3.1rem)] sticky top-[calc(var(--header-height)+3.1rem)] space-y-3 text-[0.85rem] pt-10 lg:group-[.has-toc]:block"
                x-show="!isAiOpen"
                x-transition:enter="transition ease-out duration-200"
                x-transition:enter-start="opacity-0"
                x-transition:enter-end="opacity-100"
                x-transition:leave="transition ease-in duration-150"
                x-transition:leave-start="opacity-100"
                x-transition:leave-end="opacity-0"
                aria-label="{{ 'templates.page.page_toc' | t }}"
              >
                <div data-toc-target="menu">
                  <p class="flex items-center gap-2 font-bold text-neutral-800 dark:text-neutral-200 mb-2">
                    <svg class="size-4 text-neutral-400 dark:text-neutral-500" fill="none" viewBox="0 0 24 24"
                      stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round"
                        d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zM3.75 12h.007v.008H3.75V12zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm-.375 5.25h.007v.008H3.75v-.008zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
                    </svg>
                    {{ 'templates.page.page_toc' | t }}
                  </p>
                  <div data-toc-target="links"></div>
                </div>
              </aside>
            </div>
          </div>
        </turbo-frame>
      </div>
    </div>
  </div>

  {% comment %} AI Assistant 移动端弹出层 {% endcomment %}
  <div class="fixed inset-0 z-[120] lg:hidden overscroll-none" x-show="isAiOpen"
    x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0"
    x-transition:enter-end="opacity-100" x-transition:leave="transition ease-in duration-200"
    x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0" style="display: none;">
    <div class="absolute inset-0 bg-black/40 touch-none" @click="isAiOpen = false" @touchmove.prevent></div>
    <div
      class="absolute inset-x-0 bottom-0 h-[86vh] rounded-t-2xl bg-white shadow-2xl flex flex-col overflow-hidden touch-pan-y">
      <div x-data="{ touchStartY: 0, dragY: 0, dragging: false }" class="touch-none shrink-0"
        @touchstart.passive="touchStartY = $event.touches[0].clientY; dragging = true"
        @touchmove="if (!dragging) return; let moved = $event.touches[0].clientY - touchStartY; dragY = moved > 0 ? moved : 0; $event.preventDefault(); $el.parentElement.style.transform = `translateY(${dragY}px)`; $el.parentElement.style.transition = 'none';"
        @touchend="if (dragY > 120) { isAiOpen = false }; dragging = false; dragY = 0; $el.parentElement.style.transform = ''; $el.parentElement.style.transition = 'transform 0.2s ease-out';"
        @touchcancel="dragging = false; dragY = 0; $el.parentElement.style.transform = ''; $el.parentElement.style.transition = 'transform 0.2s ease-out';">
        <div class="flex items-center justify-center pt-2 pb-1">
          <div class="h-1 w-10 rounded-full bg-neutral-300"></div>
        </div>
        <div class="flex items-center justify-between px-4 py-3">
          <div class="flex items-center gap-2 font-bold text-neutral-900 text-[0.95rem]">
            <svg class="size-4 text-emerald-500" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path
                d="m9.813 15.904-.813 2.846a4.5 4.5 0 0 1-3.09-3.09L3.064 14.85a4.5 4.5 0 0 1 3.09-3.09l2.846-.813a4.5 4.5 0 0 1 3.09 3.09l-.813 2.847a4.5 4.5 0 0 1-3.09 3.09Z" />
              <path
                d="m18.259 8.715-.259 1.035a3.375 3.375 0 0 1-2.455 2.456L14.5 12.465a3.375 3.375 0 0 1 2.455-2.456l1.035-.259a3.375 3.375 0 0 1 2.456 2.456l-.259 1.035a3.375 3.375 0 0 1-2.456-2.456Z" />
              <path
                d="m16.894 20.567-.394 1.183a2.25 2.25 0 0 1-1.423 1.423l-1.183-.394a2.25 2.25 0 0 1 1.423-1.423l.394-1.183a2.25 2.25 0 0 1 1.423 1.423l1.183.394a2.25 2.25 0 0 1-1.423-1.423Z" />
            </svg>
            Assistant
          </div>
          <button type="button" class="text-neutral-500 hover:text-neutral-700 p-1.5 rounded-lg" aria-label="Close"
            @click="isAiOpen = false">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 6 6 18"></path>
              <path d="m6 6 12 12"></path>
            </svg>
          </button>
        </div>
      </div>
      <div class="flex-1 flex items-center justify-center text-xs text-neutral-400 px-4">
        Responses are generated using AI and may contain mistakes.
      </div>
      <div class="px-4 pb-4 shrink-0">
        <div
          class="flex flex-col w-full rounded-2xl bg-white border border-neutral-200 focus-within:border-emerald-500 transition-colors">
          <div class="relative flex items-end">
            <textarea
              class="w-full bg-transparent border-0 text-neutral-900 placeholder-neutral-500 focus:outline-none focus:ring-0 py-2.5 pl-3.5 pr-10 text-[0.85rem] !pb-0 resize-none"
              placeholder="Ask a question..." style="height: 50px;"></textarea>
          </div>
          <div class="flex items-center justify-between px-2 pb-2">
            <button type="button" class="p-1 rounded-lg text-neutral-500 hover:text-neutral-700 hover:bg-neutral-100"
              aria-label="Add attachment">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none"
                stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"
                class="size-3.5">
                <path
                  d="M7.75 5V11.75C7.75 12.578 8.422 13.25 9.25 13.25C10.078 13.25 10.75 12.578 10.75 11.75V4.75C10.75 3.093 9.407 1.75 7.75 1.75C6.093 1.75 4.75 3.093 4.75 4.75V11.75C4.75 14.235 6.765 16.25 9.25 16.25C11.735 16.25 13.75 14.235 13.75 11.75V5">
                </path>
              </svg>
            </button>
            <button class="flex justify-center items-center rounded-full p-1 size-6 bg-emerald-500/10 text-emerald-500"
              aria-label="Send message" disabled="">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="size-3.5">
                <path d="m5 12 7-7 7 7"></path>
                <path d="M12 19V5"></path>
              </svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  {% comment %} AI Assistant 侧边栏（桌面） {% endcomment %}
  <div
    class="hidden lg:flex bg-slate-100 overflow-hidden z-50 w-[var(--ai-sidebar-width,340px)] sticky top-0 max-h-screen overflow-y-auto transition-[width] duration-300 [.resize-bar-dragging_&]:transition-none"
    x-show="isAiOpen" x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="opacity-0 translate-x-full" x-transition:enter-end="opacity-100 translate-x-0"
    x-transition:leave="transition ease-in duration-300" x-transition:leave-start="opacity-100 translate-x-0"
    x-transition:leave-end="opacity-0 translate-x-full" style="display: none;" data-controller="resize-bar"
    data-resize-bar-target="target" data-resize-bar-dragging-class="bg-slate-200 cursor-ew-resize !transition-none"
    data-resize-bar-min-size-value="350" data-resize-bar-max-size-value="600" data-resize-bar-direction-value="left"
    data-resize-bar-remember-value="true" data-resize-bar-key-value="ai-sidebar-width"
    data-resize-bar-css-var-value="--ai-sidebar-width">
    <div class="transition bg-slate-100 w-[6px] shrink-0 hover:bg-slate-200 hover:cursor-ew-resize"
      data-resize-bar-target="bar">
    </div>
    <div class="relative flex flex-col flex-1 bg-white dark:bg-neutral-950 min-w-0">
      <!-- AI Header -->
      <div class="flex items-center justify-between px-4 py-3 dark:border-neutral-800">
        <div class="flex items-center gap-2 font-bold text-neutral-900 dark:text-neutral-100 text-[0.95rem]">
          <svg class="size-4 text-emerald-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
            stroke-linecap="round" stroke-linejoin="round">
            <path
              d="m9.813 15.904-.813 2.846a4.5 4.5 0 0 1-3.09-3.09L3.064 14.85a4.5 4.5 0 0 1 3.09-3.09l2.846-.813a4.5 4.5 0 0 1 3.09 3.09l-.813 2.847a4.5 4.5 0 0 1-3.09 3.09Z" />
            <path
              d="m18.259 8.715-.259 1.035a3.375 3.375 0 0 1-2.455 2.456L14.5 12.465a3.375 3.375 0 0 1 2.455-2.456l1.035-.259a3.375 3.375 0 0 1 2.456 2.456l-.259 1.035a3.375 3.375 0 0 1-2.456-2.456Z" />
            <path
              d="m16.894 20.567-.394 1.183a2.25 2.25 0 0 1-1.423 1.423l-1.183-.394a2.25 2.25 0 0 1 1.423-1.423l.394-1.183a2.25 2.25 0 0 1 1.423 1.423l1.183.394a2.25 2.25 0 0 1-1.423-1.423Z" />
          </svg>
          Assistant
        </div>
        <div class="flex items-center gap-1">
          <button type="button" class="group hover:bg-neutral-100 dark:hover:bg-white/10 p-1.5 rounded-lg"
            aria-label="Expand">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
              class="size-4 sm:size-3.5 text-neutral-500 group-hover:text-neutral-700 dark:group-hover:text-neutral-300">
              <polyline points="15 3 21 3 21 9"></polyline>
              <polyline points="9 21 3 21 3 15"></polyline>
              <line x1="21" x2="14" y1="3" y2="10"></line>
              <line x1="3" x2="10" y1="21" y2="14"></line>
            </svg>
          </button>
          <button type="button" class="group hover:bg-neutral-100 dark:hover:bg-white/10 p-1.5 rounded-lg"
            aria-label="Trash">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
              class="size-4 sm:size-3.5 text-neutral-500 group-hover:text-neutral-700 dark:group-hover:text-neutral-300">
              <path d="M3 6h18"></path>
              <path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"></path>
              <path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path>
            </svg>
          </button>
          <button type="button" class="group hover:bg-neutral-100 dark:hover:bg-white/10 p-1.5 rounded-lg"
            aria-label="Close" @click="isAiOpen = false">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
              class="size-[20px] sm:size-4 text-neutral-500 group-hover:text-neutral-700 dark:group-hover:text-neutral-300">
              <path d="M18 6 6 18"></path>
              <path d="m6 6 12 12"></path>
            </svg>
          </button>
        </div>
      </div>

      <!-- AI Messages Area -->
      <div class="flex-1 flex flex-col-reverse overflow-y-auto px-5 min-h-0 relative">
        <div class="flex flex-col gap-3 mb-2">
          <div class="flex justify-end items-end w-full flex-col gap-2">
            <div class="flex px-3 py-2 items-start gap-4 w-fit rounded-2xl bg-neutral-100 dark:bg-white/5">
              <div class="flex items-start gap-4 w-full">
                <div class="flex flex-col gap-1 w-full">
                  <div class="break-words hyphens-auto text-base lg:text-sm text-neutral-800 dark:text-neutral-200">订单
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="flex flex-col py-4 gap-4 self-stretch">
            <div
              class="space-y-4 whitespace-normal prose prose-sm dark:prose-invert overflow-x-auto pb-1 max-lg:text-base">
              <p class="whitespace-pre-line leading-relaxed text-neutral-800 dark:text-neutral-200">
                您的问题"订单"过于简短。请问您想了解关于订单的什么内容？例如 API 端点、创建订单、查询订单等？</p>
