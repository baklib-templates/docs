<div class="flex flex-grow relative bg-white text-neutral-900"
  x-data="{ docTab: 'guides', isAtBottom: false, isAiOpen: localStorage.getItem('mintIsAiOpen') === 'true' }" x-init="
    const lockScroll = () => {
      const mobile = window.matchMedia('(max-width: 1023px)').matches;
      if (mobile && isAiOpen) {
        document.body.style.overflow = 'hidden';

      } else {
        document.body.style.overflow = '';
        document.documentElement.style.overflow = '';
      }
    };
    $watch('isAiOpen', val => {
      localStorage.setItem('mintIsAiOpen', val);
      lockScroll();
    });
    lockScroll();
    window.addEventListener('resize', lockScroll);
  " @scroll.window="isAtBottom = (window.scrollY + window.innerHeight >= document.documentElement.scrollHeight - 120)">
  <div class="flex-grow min-w-0">
    {%comment %} Mint 文档顶栏：与天蓝色文档风统一； {% endcomment %}
    {% render 'index/mint/header', page: page %}

    {% comment %} top channels {% endcomment %}
    <div class="sticky top-[var(--header-height)] w-full bg-white z-30 border-b border-neutral-100">
      <div class="mx-auto max-w-[var(--max-content-width)] h-12 px-4 lg:px-6">
        {% comment %} 面包屑 {% endcomment %}
        <div class="h-full flex items-center space-x-2 lg:hidden overflow-hidden">
          <label for="my-drawer-3" class="btn btn-ghost btn-sm btn-square text-neutral-500" aria-label="Open sidebar">
            <svg class="size-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </label>
          <div class="flex items-center gap-2 text-[1.05rem] scroll-y-auto">
            <span class="text-neutral-500">Get Started</span>
            <svg class="size-4 text-neutral-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd"
                d="M7.23 14.77a.75.75 0 010-1.06L10.94 10 7.23 6.29a.75.75 0 111.06-1.06l4.24 4.24a.75.75 0 010 1.06L8.29 14.77a.75.75 0 01-1.06 0z"
                clip-rule="evenodd" />
            </svg>
            <span class="font-bold text-neutral-900">Introduction</span>
          </div>
          <div class="w-8"></div>
        </div>

        {% comment %} channels {% endcomment %}
        <div class="hidden lg:flex h-full gap-4 text-[0.85rem] font-bold dark:border-neutral-800">
          <button type="button" class="relative -mb-px border-b-[3px] transition-colors"
            :class="docTab === 'guides' ? 'border-emerald-500 text-emerald-600 dark:border-emerald-400 dark:text-emerald-400' : 'border-transparent text-neutral-500 hover:text-neutral-800 dark:text-neutral-400 dark:hover:text-neutral-200'"
            @click="docTab = 'guides'">
            Guides
          </button>
          <button type="button" class="relative -mb-px border-b-[3px] transition-colors"
            :class="docTab === 'api' ? 'border-emerald-500 text-emerald-600 dark:border-emerald-400 dark:text-emerald-400' : 'border-transparent text-neutral-500 hover:text-neutral-800 dark:text-neutral-400 dark:hover:text-neutral-200'"
            @click="docTab = 'api'">
            API Reference
          </button>
        </div>
      </div>
