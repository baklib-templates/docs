{%# locals: (page:) %}
{% assign breadcrumb_size = page.breadcrumb | size %}
{% assign prev_page = nil %}
{% assign next_page = nil %}

{% if breadcrumb_size > 1 %}
  {% assign parent_index = breadcrumb_size | minus: 2 %}
  {% assign parent_path = page.breadcrumb[parent_index].path %}
  {% assign parent_page = site.pages[parent_path] %}
  {% assign siblings = parent_page.children_in_list %}
  {% assign current_index = -1 %}

  {% for sibling in siblings %}
    {% if sibling.path == page.path %}
      {% assign current_index = forloop.index0 %}
      {% break %}
    {% endif %}
  {% endfor %}

  {% if current_index > 0 %}
    {% assign prev_index = current_index | minus: 1 %}
    {% assign prev_page = siblings[prev_index] %}
  {% endif %}

  {% assign next_index = current_index | plus: 1 %}
  {% assign siblings_size = siblings | size %}
  {% if current_index >= 0 and next_index < siblings_size %}
    {% assign next_page = siblings[next_index] %}
  {% endif %}
{% endif %}

{% if prev_page or next_page %}
  <section class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2">
    {% if prev_page %}
      <a href="{{ prev_page.path }}" class="group rounded-3xl border border-neutral-200 bg-white p-6 transition-colors hover:border-neutral-300 hover:bg-neutral-50">
        <p class="text-[2rem] font-semibold tracking-tight text-neutral-900">{{ prev_page.link_text }}</p>
        <p class="mt-1 flex items-center gap-1 text-[1.45rem] text-neutral-500">
          <svg xmlns="http://www.w3.org/2000/svg" class="size-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M11.78 4.22a.75.75 0 010 1.06L7.06 10l4.72 4.72a.75.75 0 11-1.06 1.06l-5.25-5.25a.75.75 0 010-1.06l5.25-5.25a.75.75 0 011.06 0z" clip-rule="evenodd" />
          </svg>
          以前的
        </p>
      </a>
    {% else %}
      <div class="hidden sm:block"></div>
    {% endif %}

    {% if next_page %}
      <a href="{{ next_page.path }}" class="group rounded-3xl border border-neutral-200 bg-white p-6 text-right transition-colors hover:border-neutral-300 hover:bg-neutral-50">
        <p class="text-[2rem] font-semibold tracking-tight text-neutral-900">{{ next_page.link_text }}</p>
        <p class="mt-1 flex items-center justify-end gap-1 text-[1.45rem] text-neutral-500">
          下一个
          <svg xmlns="http://www.w3.org/2000/svg" class="size-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M8.22 15.78a.75.75 0 010-1.06L12.94 10 8.22 5.28a.75.75 0 111.06-1.06l5.25 5.25a.75.75 0 010 1.06l-5.25 5.25a.75.75 0 01-1.06 0z" clip-rule="evenodd" />
          </svg>
        </p>
      </a>
    {% endif %}
  </section>
{% endif %}
