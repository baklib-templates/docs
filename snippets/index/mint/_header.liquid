<header
  class="js--header sticky top-0 z-40 h-[var(--header-height)] bg-base-100/90 backdrop-blur-md supports-[backdrop-filter]:bg-base-100/80"
>
  <div
    class="mx-auto grid h-full max-w-[var(--max-content-width)] grid-cols-[minmax(0,1fr)_auto] lg:grid-cols-[minmax(0,1fr)_auto_minmax(0,1fr)] items-center gap-3 border-b border-base-200 px-4 lg:px-6">
    {% assign mint_default_site_icon = 'images/mint-default-site-icon.svg' | asset_url %}
    <a href="{{ site.index_path }}"
      class="flex min-w-0 items-center gap-2 justify-self-start font-semibold tracking-tight text-base-content">
      {% assign logo_url = site.settings.logo_url | presence %}
      {% if logo_url %}
        <span class="inline-flex h-8 max-h-8 shrink-0 items-center justify-center">
          <img src="{{ logo_url }}" class="h-full w-auto max-w-[10rem] rounded-md object-contain" width="160" height="32" alt="{{ site.name | escape_once }}">
        </span>
      {% else %}
        {% assign favicon_url = site.favicon_url | presence | default: mint_default_site_icon %}
        {% if favicon_url %}
          <span class="inline-flex size-8 shrink-0 items-center justify-center overflow-hidden rounded-md bg-base-200" aria-hidden="true">
            <img src="{{ favicon_url }}" class="size-6 object-contain" width="24" height="24" alt="">
          </span>
        {% endif %}
        <span class="truncate text-[1.1rem] font-extrabold tracking-tight">{{ site.name }}</span>
      {% endif %}
    </a>

    <div class="hidden min-w-0 flex-1 items-center justify-center gap-2.5 lg:flex">
      <button
        type="button"
        class="flex h-9 w-full min-w-[16.5rem] max-w-[22rem] cursor-pointer items-center rounded-lg border border-base-200 bg-base-200/50 px-2.5 text-left text-[0.85rem] text-base-content/50 shadow-inner transition-colors hover:border-base-300 hover:bg-base-200"
        data-action="click->header-search#openModal"
        aria-haspopup="dialog"
      >
        <i class="ri-search-line shrink-0 text-[0.95rem] leading-none text-base-content/45" aria-hidden="true"></i>
        <span class="ml-2.5 min-w-0 flex-1 truncate">{{ 'search.placeholder' | t: 'Search...' }}</span>
      </button>
      <button type="button" @click="toggleAiAssistant()"
        class="btn btn-ghost btn-sm h-[2.125rem] shrink-0 gap-1.5 rounded-lg border border-base-300 px-3.5 font-bold text-base-content/80 hover:bg-base-200">
        <i class="ri-sparkling-2-line shrink-0 text-[0.95rem] leading-none text-primary" aria-hidden="true"></i>
        {{ 'snippets.header.ask_ai' | t: 'Ask AI' }}
      </button>
    </div>

    <div class="hidden lg:flex shrink-0 items-center justify-end gap-3 sm:gap-4">
      {% assign header_menu_html = site.settings.header_menu_html | presence %}
      {% if header_menu_html %}
        {% comment %} 分割线 {% endcomment %}
        <div class="hidden lg:block w-px h-4 bg-base-300"></div>
        <div class="hidden lg:flex flex-1 justify-end min-w-0">
          <div class="flex items-center gap-6">{{ header_menu_html }}</div>
        </div>
      {% endif %}

      {% if current_user %}
        <span class="hidden h-6 w-px shrink-0 bg-base-300 sm:block dark:bg-base-content/15" aria-hidden="true"></span>
        <div class="flex shrink-0 items-center">
          <div class="dropdown dropdown-end">
            <div tabindex="0" role="button" class="{{ header_icon_btn }}" aria-label="{{ current_user.name | escape_once }}">
              {% if current_user.image %}
                <img src="{{ current_user.image }}" alt="" class="size-7 rounded-lg object-cover sm:size-8" width="32" height="32" />
              {% else %}
                <svg class="size-4 text-base-content/60 sm:size-[1.125rem]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                  <circle cx="12" cy="8" r="4" />
                  <path d="M4 20c0-4 8-4 8-4s8 0 8 4" />
                </svg>
              {% endif %}
            </div>
            <div tabindex="0" class="dropdown-content rounded-box mt-2 w-44 space-y-3 bg-base-100 px-3 py-2 shadow">
              <div class="line-clamp-1 border-b border-base-200 pb-2 font-medium text-primary">{{ current_user.name }}</div>
              <div class="text-base-content/60">
                {% form_tag 'sign_out' %}
                  <button type="submit" class="h-5 w-full text-left hover:link">{{ 'generic.buttons.signout' | t }}</button>
                {% endform_tag %}
              </div>
            </div>
          </div>
        </div>
      {% endif %}
    </div>

    <div class="flex lg:hidden items-center gap-3">
      <button type="button"
        class="btn btn-ghost btn-sm btn-square text-base-content/60"
        id="search-bar-entry-mobile"
        data-action="click->header-search#openModal"
        aria-label="{{ 'search.placeholder' | t: '搜索...' }}"
        aria-haspopup="dialog">
        <span class="sr-only">{{ 'search.placeholder' | t: '搜索...' }}</span>
        <i class="ri-search-line text-base leading-none" aria-hidden="true"></i>
      </button>
      <button id="assistant-entry-mobile" type="button" class="btn btn-ghost btn-sm btn-square text-base-content/60" @click="toggleAiAssistant()" aria-label="{{ 'snippets.header.ask_ai' | t: 'Ask AI' }}">
        <i class="ri-sparkling-2-line text-base leading-none text-primary" aria-hidden="true"></i>
      </button>

      {% if header_menu_html %}
        <div class="dropdown dropdown-end">
          <div tabindex="0" role="button" class="btn btn-ghost btn-sm btn-square h-7 w-7 min-h-0 p-0">
            <i class="ri-more-2-line text-base leading-none" aria-hidden="true"></i>
          </div>
          <div class="dropdown-content menu bg-base-100 rounded-box z-1 w-52 p-2 shadow-sm">
              {{ header_menu_html }}
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</header>