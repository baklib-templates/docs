{% assign min_depth = min_depth | default: 1 %}
{% assign depth = breadcrumb | size %}
{% if depth > min_depth %}
  <nav class="flex flex-wrap items-center gap-x-2 text-sm leading-normal" aria-label="面包屑">
    {% for crumb in breadcrumb %}
      {% if forloop.index0 != 0 %}
        {% if forloop.index0 > 1 %}
          <span class="shrink-0 text-gray-400 select-none dark:text-gray-500" aria-hidden="true">></span>
        {% endif %}
        {% if forloop.last %}
          <span class="line-clamp-1 font-normal text-gray-900 dark:text-gray-100">{{ crumb.link_text }}</span>
        {% else %}
          <a
            href="{{ crumb.path }}"
            data-turbo-frame="_top"
            class="line-clamp-1 text-gray-500 transition-colors hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-300"
          >
            {{- crumb.link_text -}}
          </a>
        {% endif %}
      {% endif %}
    {% endfor %}
  </nav>
{% endif %}
