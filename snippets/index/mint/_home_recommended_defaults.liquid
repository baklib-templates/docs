      <span class="flex size-8 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary">
        <i class="ri-file-text-line text-sm" aria-hidden="true"></i>
      </span>
      <span class="line-clamp-2 text-sm font-medium text-base-content/80">
        {{ 'snippets.mint.home.rec_default_1' | t: '快速开始：环境准备与首次部署' }}
      </span>
    </div>
    <span class="shrink-0 text-[0.7rem] text-base-content/45">{{ 'snippets.mint.home.tag_recent' | t: '最近更新' }}</span>
  </div>
</li>
