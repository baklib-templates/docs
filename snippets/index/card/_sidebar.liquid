{% comment %} Tree文档布局左侧栏顶区：搜索 + Ask AI {% endcomment %}

<div class="shrink-0 space-y-3 px-2 pb-3 pt-3 lg:px-3 lg:pt-4">
  <div class="relative hidden items-center gap-2 lg:flex">
    <button
      type="button"
      class="group/search flex h-9 min-w-0 flex-1 cursor-pointer items-center justify-between gap-2 rounded-xl bg-base-100 px-3.5 text-left text-sm text-base-content/50 ring-1 ring-base-300/60 transition hover:ring-base-content/25"
      data-action="click->header-search#openModal"
      aria-haspopup="dialog"
      id="search-bar-entry"
    >
      <span class="flex min-w-0 items-center gap-2">
        <i class="ri-search-line shrink-0 text-base text-base-content/45 group-hover/search:text-base-content/70" aria-hidden="true"></i>
        <span class="truncate">{{ 'snippets.card.home.search_placeholder' | t: 'Search...' }}</span>
      </span>
      <kbd class="hidden shrink-0 text-xs font-semibold text-base-content/40 sm:inline">⌘K</kbd>
    </button>
    <button
      type="button"
      class="flex size-9 shrink-0 cursor-pointer items-center justify-center rounded-xl bg-base-100 text-primary ring-1 ring-base-300/60 transition hover:ring-base-content/25"
      id="assistant-entry"
      @click="toggleAiAssistant()"
      aria-label="{{ 'snippets.header.ask_ai' | t: '问 AI' }}"
    >
      <i class="ri-sparkling-2-line text-base leading-none" aria-hidden="true"></i>
    </button>
  </div>
</div>
