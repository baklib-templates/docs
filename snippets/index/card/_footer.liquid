{% assign footer_menu_html = site.settings.footer_menu_html | presence %}
{% assign company_name = site.settings.company_name | presence | default: site.name %}
{% assign copyright_info = site.settings.copyright_info | presence %}
{% assign year = 'now' | date: '%Y' %}

{% if footer_menu_html %}
  <div class="flex flex-wrap items-center justify-center gap-4 sm:justify-end">
    {{ footer_menu_html }}
  </div>
{% else %}
  <footer class="border-t border-base-200 py-8 text-[0.85rem] text-base-content/60 print:hidden">
    <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
      <div class="flex flex-wrap items-center justify-center gap-x-3 gap-y-1 text-center sm:justify-start sm:text-left">
        <p class="m-0">
          © {{ year }} {{ company_name }}
          <span class="text-base-content/50">{{ 'snippets.footer.copyright' | t: '版权所有' }}</span>
        </p>
        {% if copyright_info %}
          <a
            href="https://beian.miit.gov.cn/"
            target="_blank"
            rel="noopener noreferrer"
            class="link link-hover text-base-content/60 hover:text-base-content"
          >
            {{- copyright_info -}}
          </a>
        {% endif %}
      </div>
    </div>
  </footer>
{% endif %}