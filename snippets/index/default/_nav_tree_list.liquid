{%# locals: (page:, current_path:) %}

{% assign count = page.children_in_list | size %}
<div class="space-y-1 custom-menu">
  {% if count > 0 %}
    {% if count > 100 %}
      {% assign parent_path = page.path %}
      <turbo-frame class='w-full' id="index_default_nav_tree_frame_{{ parent_path | replace: '/', '_' }}" src="{{ statics['index/default/nav_tree'] }}?parent_path={{ parent_path }}&depth=1" loading="lazy">
        <div class="flex items-center justify-center h-20 text-base-content/60 bg-none">
          <span class="loading loading-spinner loading-md"></span>
        </div>
      </turbo-frame>
    {% else %}
      {% assign data = page | nav_tree: 2, include_settings: 'icon' %}
      {% render 'index/default/nav_tree', nav_tree: data, depth: 1, current_path: current_path %}
    {% endif %}
  {% else %}
    <div>
      <a
        href="{{ page.path }}"
        data-turbo-frame="main-content-frame"
        data-turbo-action="advance"
        class="flex items-center gap-2 rounded-lg px-3 py-1.5 text-sm font-medium transition-colors"
        :class="channelPathActive('{{ page.path }}', 0, true) ? 'bg-primary/10 text-primary' : 'text-base-content/80 hover:bg-base-200/60'"
      >{{ page.link_text }}</a>
    </div>
  {% endif %}
</div>
