{% comment %}
  Mintlify Maple–style document header: eyebrow, H1, optional Copy page tools,
  lead paragraph, optional inline hero image (when background type = image).
{% endcomment %}

{% assign kicker = page.settings.hero_kicker | presence %}
{% assign title = page.settings.hero_slogan | presence | default: page.link_text %}
{% assign intro = page.settings.hero_intro | presence %}

<header class="mb-8 border-b border-base-content/10 pb-8 text-left">
  {% if kicker %}
    <p class="mb-2 text-xs font-semibold uppercase tracking-wider text-[color:var(--maple-accent,#a34e36)]">
      {{ kicker }}
    </p>
  {% endif %}

  <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
    {% if title %}
      <h1 class="m-0 max-w-3xl text-3xl font-bold tracking-tight text-base-content md:text-4xl lg:text-[2.75rem] lg:leading-[1.15]">
        {{ title }}
      </h1>
    {% endif %}
    {% if site.settings.show_page_tools_dropdown %}
      <div class="shrink-0 self-start sm:pt-1">
        {% render 'page_tools_dropdown', page: page %}
      </div>
    {% endif %}
  </div>

  {% if intro %}
    <p class="mb-0 mt-4 max-w-3xl text-base leading-relaxed text-base-content/70">
      {{ intro | newline_to_br }}
    </p>
  {% endif %}

  {% if page.settings.hero_bg_type.value == '2' %}
    {% assign hero_img = page.settings.hero_image_url | presence %}
    {% if hero_img %}
      <figure class="mb-0 mt-8 overflow-hidden rounded-2xl border border-base-content/10 bg-base-200/40 shadow-sm dark:bg-base-200/20">
        <img
          src="{{ hero_img | escape_once }}"
          alt=""
          class="max-h-[min(420px,56vh)] w-full object-cover"
          loading="lazy"
          width="1200"
          height="420"
        />
      </figure>
    {% endif %}
  {% endif %}
</header>
