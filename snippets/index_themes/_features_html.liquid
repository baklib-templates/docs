{% comment %}
  Optional custom HTML block configured via site.settings.features_one_html /
  features_two_html. Render nothing when empty.

  Required param:
    html : raw html string (e.g. site.settings.features_one_html)
{% endcomment %}

{% assign _html = html | strip %}
{% if _html | present? %}
  <section>
    {{ _html }}
  </section>
{% endif %}
