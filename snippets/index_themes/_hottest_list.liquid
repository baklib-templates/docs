{% comment %}
  Hottest topics list (originally `show_hottest_section`).

  Optional params:
    item_limit : integer    default 10
    style      : 'card' | 'plain'   default 'card'
{% endcomment %}

{% assign _limit = item_limit | default: 10 %}
{% assign _style = style | default: 'card' %}
{% assign hottest_pages = site.pages['/'].pages_in_list | order_by: '-visits_count' | limit: _limit %}

<section class="bg-transparent">
  {% assign hottest_section_title = page.settings.hottest_section_title | presence %}
  {% if hottest_section_title %}
    <h2 class="flex items-center h-8 mb-4 text-2xl font-bold text-slate-800 dark:text-slate-200 m-0">
      <span class="w-1 h-full mr-3 shrink-0 bg-primary" aria-hidden="true"></span>
      <span>{{ hottest_section_title }}</span>
    </h2>
  {% endif %}

  <div class="grid grid-cols-1 gap-4 md:grid-cols-2 p-4 gap-y-4 text-slate-800 dark:text-slate-200 rounded-md overflow-hidden
    {% if _style == 'plain' %}bg-transparent{% else %}bg-white dark:bg-slate-800{% endif %}">
    {% for hot_page in hottest_pages %}
      <a class="flex items-center justify-between transition transform group" href="{{ hot_page.path }}">
        <div class="flex">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-gray-400 transition group-hover:text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
          </svg>
          <span class="ml-2 transition text-gray-550 group-hover:text-primary">
            {{ hot_page.link_text }}
          </span>
        </div>
        <svg xmlns="http://www.w3.org/2000/svg" class="flex-shrink-0 w-5 h-5 mr-4 text-gray-500 transition group-hover:text-primary group-hover:translate-x-3 md:transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    {% endfor %}
  </div>
</section>
