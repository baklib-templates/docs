{% comment %}
  Hero block: slogan, optional subtitle, optional CTA, search input,
  popular tags, popular keywords.

  Optional params (all optional, sane defaults):
    search_shape  : 'rounded' | 'pill' | 'square'   default 'rounded'
    hero_align    : 'center'  | 'left'              default 'center'
    show_slogan   : true | false                    default true
    show_search   : true | false                    default true
    cta_text      : extra primary CTA label (Aspen-style)
    cta_href      : CTA url
    subtitle      : optional descriptive line shown beneath the slogan
                    (Sequoia / Luma style)
    slogan_size   : 'normal' | 'jumbo'              default 'normal'
{% endcomment %}

{% assign _shape       = search_shape | default: 'rounded' %}
{% assign _align       = hero_align | default: 'center' %}
{% assign _slogan_size = slogan_size | default: 'normal' %}
{% assign _show_slogan = show_slogan %}
{% if _show_slogan == nil %}{% assign _show_slogan = true %}{% endif %}
{% assign _show_search = show_search %}
{% if _show_search == nil %}{% assign _show_search = true %}{% endif %}

<div class="container flex flex-col h-full m-auto mb-10" style="height: {{ page.settings.hero_height }}px;">
  <div class="flex flex-col {% if _align == 'left' %}items-start text-left{% else %}items-center text-center{% endif %} justify-center flex-grow w-full">
    {% if _show_slogan %}
      {% assign hero_slogan = page.settings.hero_slogan | presence %}
      {% if hero_slogan %}
        <h1 class="py-2 my-4 leading-tight font-bold transition duration-500 md:mt-0 text-shadow
          {% if _slogan_size == 'jumbo' %}text-3xl md:text-5xl lg:text-6xl tracking-tight
          {% else %}text-2xl md:text-4xl{% endif %}">
          {{ hero_slogan }}
        </h1>
      {% endif %}
    {% endif %}

    {% if subtitle %}
      <p class="-mt-1 mb-6 max-w-2xl text-base md:text-lg leading-relaxed text-base-content/60 {% if _align == 'center' %}mx-auto{% endif %}">
        {{ subtitle }}
      </p>
    {% endif %}

    {% if cta_text and cta_href %}
      <a href="{{ cta_href }}" class="inline-flex items-center gap-2 px-5 py-2.5 mb-6 rounded-full bg-primary text-white font-medium hover:opacity-90 transition">
        {{ cta_text }}
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    {% endif %}

    {% if _show_search %}
      <div class="z-0 flex flex-col items-center justify-center w-full md:w-2/3 {% if page.settings.hero_bg_type.value == '2' %} backdrop-blur-xl p-5 shadow rounded-md {% endif %}">
        {% form_tag 'search', class: 'w-full' %}
          <div class="relative">
            <button type="button" class="pointer-events-none absolute inset-y-0 right-0 flex items-center pl-5 pr-3 sm:right-auto">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-gray-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" > <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /> </svg>
            </button>
            <input
              type="search"
              name="{{form.keywords_field_name}}" value="{{ search.keywords | escape_once }}"
              placeholder="{{ "layout.theme.search_input_placeholder" | t }}"
              autocomplete="off"
              class="block w-full h-14 pr-6 pl-12 text-lg transition duration-300 ease-in-out bg-white dark:bg-gray-600 bg-opacity-75 focus:bg-opacity-90 placeholder:text-gray-300 outline-none
                {% if _shape == 'pill' %}rounded-full
                {% elsif _shape == 'square' %}rounded-md
                {% else %}rounded-full
                {% endif %}
                {% if page.settings.hero_bg_type.value == '0' %}
                  border border-gray-200 dark:border-slate-700 hover:ring-4 hover:ring-primary hover:bg-primary/10 dark:hover:ring-slate-500 dark:hover:bg-slate-600
                {% elsif page.settings.hero_bg_type.value == '2' %}
                  border border-gray-200 dark:border-slate-700  bg-white
                {% else %}
                  border-none hover:ring-4 hover:ring-primary
                {% endif %}
              "
            >
          </div>
        {% endform_tag %}

        <div class='space-y-1 w-full mt-2'>
          {% assign search_hot_tags = page.settings.search_hot_tags %}
          {% if search_hot_tags.size > 0 %}
            <div class="items-center justify-start w-full md:flex flex-wrap md:px-5">
              <div class="inline-block text-sm {% if page.settings.hero_bg_type.value == '2' %} text-white {% else %} text-gray-500 {% endif %} text-gray-500 dark:text-gray-100">
                <span class="mr-2">{{ 'layout.theme.search_tags_label' | t }}:</span>
                {% for tag in search_hot_tags %}
                  <a
                    href="{{ tag.path }}"
                    data-turbo-frame="_top"
                    class="mr-2 hover:text-primary focus:ring hover:-translate-y-[2px] min-w-12"
                  >
                    {{ tag.name }}
                  </a>
                {% endfor %}
              </div>
            </div>
          {% endif %}

          {% assign hot_keywords = page.settings.search_hot_keywords | reg_split: "/\n/" %}
          {% if hot_keywords.size > 0 %}
            <div class="items-center justify-start w-full md:flex flex-wrap md:px-5">
              <div class="inline-block text-sm {% if page.settings.hero_bg_type.value == '2' %} text-white {% else %} text-gray-500 {% endif %} dark:text-gray-100">
                <span class="mr-2">{{ 'layout.theme.search_keywords_label' | t: '热门搜索' }}:</span>
                {% for hot_keyword in hot_keywords %}
                  <a
                    href="{{site.index_path}}-/search?q={{ hot_keyword }}"
                    class="mr-2 hover:text-primary focus:ring hover:-translate-y-[2px] underline"
                  >
                    {{ hot_keyword }}
                  </a>
                {% endfor %}
              </div>
            </div>
          {% endif %}
        </div>
      </div>
    {% endif %}
  </div>
</div>
