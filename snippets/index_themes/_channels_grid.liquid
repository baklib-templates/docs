{% comment %}
  First-section card grid (Mintlify-style "Get started" tiles).

  Optional params:
    columns        : 2 | 3 | 4    default 3
    card_style     : 'gradient' | 'outline' | 'flat' | 'glass'  default 'gradient'
    item_limit     : integer      default 3
    section_align  : 'center' | 'left'   default 'center'
    tile_style     : 'default' | 'doc'   default 'default' (doc = Mintlify Maple outline tiles)
{% endcomment %}

{% assign _columns       = columns | default: 3 %}
{% assign _card_style    = card_style | default: 'gradient' %}
{% assign _limit         = item_limit | default: 3 %}
{% assign _section_align = section_align | default: 'center' %}
{% assign _tile_style    = tile_style | default: 'default' %}

<section class="">
  {% assign channels_section_title = page.settings.channels_section_title | presence %}
  {% if channels_section_title %}
    <div class="{% if _section_align == 'left' %}my-6 text-left md:mb-8{% else %}my-4 items-center text-center md:mb-8{% endif %}">
      <h2 class="m-0 text-xl font-semibold tracking-tight md:text-2xl">{{ channels_section_title }}</h2>
    </div>
  {% endif %}

  <div class="items-start lg:max-w-none grid grid-cols-1 gap-2 md:gap-8
    {% if _columns == 2 %}md:grid-cols-2
    {% elsif _columns == 4 %}md:grid-cols-2 lg:grid-cols-4
    {% else %}md:grid-cols-3
    {% endif %}">
    {% assign card_pages = site.pages['/'].children_in_nav_menu | limit: _limit %}
    {% for card_page in card_pages %}
      {% if _tile_style == 'doc' %}
        <a
          href="{{ card_page.path }}"
          class="group relative flex flex-col gap-2 rounded-xl border border-base-content/15 bg-base-100 p-5 transition hover:border-[color:var(--maple-accent,#a34e36)] hover:shadow-sm dark:border-base-content/20"
        >
          <div class="flex items-start justify-between gap-3">
            <div class="flex min-w-0 flex-1 items-start gap-3">
              {% if card_page.settings.icon %}
                <img
                  src="{{ card_page.settings.icon }}"
                  alt=""
                  class="size-10 shrink-0 rounded-lg border border-base-content/10 object-cover"
                  loading="lazy"
                  width="40"
                  height="40"
                />
              {% else %}
                <span
                  class="flex size-10 shrink-0 items-center justify-center rounded-lg bg-[color:var(--maple-accent,#a34e36)]/12 text-[color:var(--maple-accent,#a34e36)]"
                  aria-hidden="true"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="size-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                  </svg>
                </span>
              {% endif %}
              <div class="min-w-0 flex-1">
                <p class="m-0 text-base font-semibold leading-snug text-base-content">{{ card_page.link_text }}</p>
                {% assign desc = card_page.settings.description | presence %}
                {% if desc %}
                  <p class="mb-0 mt-1 text-sm leading-relaxed text-base-content/65">{{ desc }}</p>
                {% endif %}
              </div>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" class="size-5 shrink-0 text-base-content/35 transition group-hover:text-[color:var(--maple-accent,#a34e36)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 19.5 15-15m0 0H8.25m11.25 0v11.25" />
            </svg>
          </div>
        </a>
      {% else %}
        <a href="{{ card_page.path }}"
          class="flex flex-col h-full overflow-hidden
            {% if _card_style == 'outline' %}
              bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg hover:border-primary hover:shadow-sm
            {% elsif _card_style == 'flat' %}
              bg-white dark:bg-slate-800 rounded-md hover:bg-slate-50 dark:hover:bg-slate-700
            {% elsif _card_style == 'glass' %}
              bg-white/60 dark:bg-slate-800/60 backdrop-blur rounded-lg border border-white/40 hover:bg-white/80
            {% else %}
              bg-white shadow-xs rounded bg-gradient-to-b from-secondary-100 from-5% to-primary-50/80 to-80% hover:from-secondary-100 hover:to-primary-100
            {% endif %}">
          <div class="flex-1 flex flex-col p-4 md:p-6 relative">
            <div class="flex-1">
              <header class="mb-2 md:p-0 z-10">
                <div class="flex items-center justify-start">
                  <p class="line-clamp-2 text-md md:text-xl md:font-semibold m-0">{{ card_page.link_text }}</p>
                </div>
              </header>
              <div class="h-22 md:h-44">
                <span class="text-gray-500 line-clamp-2">{{ card_page.settings.description }}</span>
                <div class="absolute -bottom-0 -right-0 opacity-60"><img src="{{ card_page.settings.icon }}" class="object-cover h-10 md:h-35"/></div>
              </div>
            </div>
          </div>
        </a>
      {% endif %}
    {% endfor %}
  </div>
</section>
