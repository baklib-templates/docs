{% comment %}
  Topic / featured channels grid.

  Optional params:
    columns       : 2 | 3 | 4    default 3
    section_align : 'center' | 'left'   default 'center'
    tile_style    : 'default' | 'doc'   default 'default'
{% endcomment %}

{% assign _columns       = columns | default: 3 %}
{% assign _section_align = section_align | default: 'center' %}
{% assign _tile_style    = tile_style | default: 'default' %}

<section class="">
  {% assign topic_channel_title = page.settings.topic_channel_title | presence %}
  {% if topic_channel_title %}
    <div class="{% if _section_align == 'left' %}my-10 text-left md:mb-8{% else %}my-4 items-center text-center md:mb-8{% endif %}">
      <h2 class="m-0 text-xl font-semibold tracking-tight md:text-2xl">{{ topic_channel_title }}</h2>
    </div>
  {% endif %}

  <div class="items-start lg:max-w-none grid grid-cols-2 gap-2 md:gap-4
    {% if _columns == 2 %}md:grid-cols-2
    {% elsif _columns == 4 %}md:grid-cols-2 lg:grid-cols-4
    {% else %}md:grid-cols-3
    {% endif %}">
    {% query topic_channels from site.pages %}
      {
        "where": {
          "settings.is_topic_channel_eq": true
        }
      }
    {% endquery %}
    {% for card_page in topic_channels %}
      {% if _tile_style == 'doc' %}
        <a
          href="{{ card_page.path }}"
          class="group relative flex flex-col gap-2 rounded-xl border border-base-content/15 bg-base-100 p-5 transition hover:border-[color:var(--maple-accent,#a34e36)] hover:shadow-sm dark:border-base-content/20"
        >
          <div class="flex items-start justify-between gap-3">
            <div class="flex min-w-0 flex-1 items-start gap-3">
              {% if site.settings.show_card_icon and card_page.settings.icon %}
                <img
                  src="{{ card_page.settings.icon }}"
                  alt=""
                  class="size-10 shrink-0 rounded-lg border border-base-content/10 object-cover"
                  loading="lazy"
                  width="40"
                  height="40"
                />
              {% else %}
                <span
                  class="flex size-10 shrink-0 items-center justify-center rounded-lg bg-[color:var(--maple-accent,#a34e36)]/12 text-[color:var(--maple-accent,#a34e36)]"
                  aria-hidden="true"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="size-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655-5.653a2.548 2.548 0 0 1-.722-1.732V6.69c0-.405.161-.794.448-1.081l.706-.706a2.548 2.548 0 0 1 3.616 0l4.243 4.243a2.548 2.548 0 0 1 0 3.616l-3.03 2.496Z" />
                  </svg>
                </span>
              {% endif %}
              <div class="min-w-0 flex-1">
                <p class="m-0 text-base font-semibold leading-snug text-base-content">{{ card_page.link_text }}</p>
                {% assign desc = card_page.settings.description | presence %}
                {% if desc %}
                  <p class="mb-0 mt-1 text-sm leading-relaxed text-base-content/65">{{ desc }}</p>
                {% endif %}
              </div>
            </div>
            <svg xmlns="http://www.w3.org/2000/svg" class="size-5 shrink-0 text-base-content/35 transition group-hover:text-[color:var(--maple-accent,#a34e36)]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 19.5 15-15m0 0H8.25m11.25 0v11.25" />
            </svg>
          </div>
        </a>
      {% else %}
        <a href="{{ card_page.path }}" class="flex flex-col h-full bg-white dark:bg-slate-800 hover:bg-opacity-50 rounded-md overflow-hidden">
          <div class="flex-1 flex flex-col p-2 md:p-6">
            <div class="flex-1">
              <header class="my-2 md:mb-2">
                <div class="flex flex-col text-center md:text-left items-center md:items-start">
                  {% if site.settings.show_card_icon %}
                    {% if card_page.settings.icon %}
                      <span class="mb-2"><img src="{{ card_page.settings.icon }}" class="h-10"/> </span>
                    {% else %}
                      <span class="mb-2">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-10 w-10 h-10 text-primary dark:text-white">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M6 6.878V6a2.25 2.25 0 0 1 2.25-2.25h7.5A2.25 2.25 0 0 1 18 6v.878m-12 0c.235-.083.487-.128.75-.128h10.5c.263 0 .515.045.75.128m-12 0A2.25 2.25 0 0 0 4.5 9v.878m13.5-3A2.25 2.25 0 0 1 19.5 9v.878m0 0a2.246 2.246 0 0 0-.75-.128H5.25c-.263 0-.515.045-.75.128m15 0A2.25 2.25 0 0 1 21 12v6a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 18v-6c0-.98.626-1.813 1.5-2.122" />
                        </svg>
                      </span>
                    {% endif %}
                  {% endif %}
                  <p class="line-clamp-1 text-md md:text-xl md:font-semibold m-0">{{ card_page.link_text }}</p>
                </div>
              </header>
              <div class="my-4 relative">
                <span class="hidden md:flex text-sm text-gray-500 dark:text-gray-300">{{ card_page.settings.description }}</span>
              </div>
            </div>
          </div>
        </a>
      {% endif %}
    {% endfor %}
  </div>
</section>
