{
  "name": "blog",
  "version": "2.1.1",
  "license": "MIT",
  "scripts": {
    "build": "npm-run-all build:icons --parallel build:css build:js",
    "build:icons": "cp ./node_modules/remixicon/fonts/remixicon.woff2 ./assets/stylesheets/remixicon.woff2 && cp ./node_modules/remixicon/fonts/remixicon.woff ./assets/stylesheets/remixicon.woff && cp ./node_modules/remixicon/fonts/remixicon.ttf ./assets/stylesheets/remixicon.ttf",
    "build:css": "npx @tailwindcss/cli -i ./src/stylesheets/application.css -o ./assets/stylesheets/application.css",
    "build:js": "npx esbuild ./src/javascripts/application.js --bundle --minify --outfile=./assets/javascripts/application.js",
    "dev": "npm-run-all build:icons --parallel 'build:css --watch' 'build:js --watch'",
    "livereload": "guard"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.4",
    "daisyui": "^5.0.27",
    "esbuild": "^0.25.9",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^4.1.4"
  },
  "dependencies": {
    "@alpinejs/collapse": "^3.15.0",
    "@hotwired/stimulus": "^3.2.2",
    "@hotwired/turbo": "^8.0.18",
    "alpinejs": "^3.15.0",
    "marked": "^16.4.0",
    "mustache": "^4.2.0",
    "remixicon": "^4.9.1",
    "tippy.js": "^6.3.7",
    "viewerjs": "^1.11.7"
  }
}
